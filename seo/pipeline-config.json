{
  "version": 1,
  "mode": "draft-only-hourly",
  "max_articles_per_run": 1,
  "publish_after_generation": false,
  "require_human_approval": true,
  "run_frequency": "hourly",
  "content_scope": [
    "Hermes",
    "Codex",
    "Claude",
    "Claude Code",
    "GPT",
    "GLM",
    "MiniMax",
    "AI CLI",
    "AI agent workflows",
    "mainstream AI development topics"
  ],
  "allowed_article_types": [
    "install-guide",
    "troubleshooting",
    "comparison",
    "best-practice"
  ],
  "required_outputs": [
    "brief",
    "research",
    "outline",
    "draft",
    "review-report"
  ],
  "required_checks_before_publish": [
    "npm run verify:blog",
    "npm run build:verify-blog"
  ],
  "selection_rules": {
    "avoid_existing_blog_topics": true,
    "avoid_existing_seo_briefs": true,
    "avoid_existing_drafts": true,
    "prefer_high_priority_topics": true
  },
  "source_rules": {
    "repository_facts_first": true,
    "allow_external_sources_only_when_needed": true,
    "must_not_invent_commands_or_links": true
  },
  "delivery_rules": {
    "deliver_summary_to_chat": true,
    "include_generated_paths": true,
    "include_reason_for_topic_selection": true,
    "include_publish_recommendation": true
  }
}
