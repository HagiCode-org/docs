---
import Page from '../../../../node_modules/starlight-blog/components/Page.astro';
import config from 'virtual:starlight-blog/config';
import starlightConfig from 'virtual:starlight/user-config';

import { DefaultLocale, type Locale } from '../../../../node_modules/starlight-blog/libs/i18n.ts';
import {
  getPageProps,
  getPathWithLocale,
  getRelativeBlogUrl,
} from '../../../../node_modules/starlight-blog/libs/page.ts';
import { getAllTags } from '../../../../node_modules/starlight-blog/libs/tags.ts';
import CompactPosts from '../components/CompactPosts.astro';

export const prerender = true;

export async function getStaticPaths() {
  const locales = starlightConfig.isMultilingual
    ? Object.keys(starlightConfig.locales).map((localeKey) => (localeKey === 'root' ? undefined : localeKey))
    : [DefaultLocale];

  return Promise.all(
    locales.map(async (locale) => {
      const tagEntries = await getAllTags(locale);
      const tags = [...tagEntries.entries()]
        .sort(([, a], [, b]) => {
          if (a.entries.length === b.entries.length) {
            return a.label.localeCompare(b.label);
          }

          return b.entries.length - a.entries.length;
        })
        .map(([slug, { entries, label }]) => ({
          slug,
          label,
          entries,
          href: getRelativeBlogUrl('/tags', locale) + `#${slug}`,
        }));

      return {
        params: {
          prefix: getPathWithLocale(config.prefix, locale),
        },
        props: {
          locale,
          tags,
        },
      };
    }),
  );
}

interface Props {
  locale: Locale;
  tags: Array<{
    entries: Awaited<ReturnType<typeof getAllTags>> extends Map<string, infer Value>
      ? Value extends { entries: infer Entries }
        ? Entries
        : never
      : never;
    href: string;
    label: string;
    slug: string;
  }>;
}

const { locale, tags } = Astro.props;
const pageProps = getPageProps(Astro.locals.t('starlightBlog.sidebar.tags'));
---

<Page {...pageProps}>
  <nav class="tag-directory" aria-label={Astro.locals.t('starlightBlog.sidebar.tags')} data-pagefind-ignore>
    {tags.map((tag) => (
      <a class="tag-directory__link" href={tag.href}>
        <span>{tag.label}</span>
        <span class="tag-directory__count">{tag.entries.length}</span>
      </a>
    ))}
  </nav>

  <div class="tag-sections">
    {tags.map((tag) => (
      <section class="tag-section" id={tag.slug}>
        <header class="tag-section__header">
          <h2>{tag.label}</h2>
          <span class="tag-section__count">{tag.entries.length}</span>
        </header>
        <CompactPosts entries={tag.entries} locale={locale} showDate={false} />
      </section>
    ))}
  </div>
</Page>

<style>
  .tag-directory {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.5rem;
  }

  .tag-directory__link {
    align-items: center;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    color: var(--sl-color-white);
    display: inline-flex;
    gap: 0.5rem;
    line-height: 1;
    padding: 0.55rem 0.8rem;
    text-decoration: none;
  }

  .tag-directory__link:hover {
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-text-accent);
  }

  .tag-directory__count,
  .tag-section__count {
    background: var(--sl-color-hairline-light);
    border-radius: 999px;
    color: var(--sl-color-gray-2);
    display: inline-flex;
    font-size: var(--sl-text-xs);
    font-variant-numeric: tabular-nums;
    justify-content: center;
    min-width: 1.8rem;
    padding: 0.2rem 0.45rem;
  }

  .tag-sections {
    display: grid;
    gap: 1.75rem;
    margin-top: 1.75rem;
  }

  .tag-section {
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 1.25rem;
    scroll-margin-top: 6rem;
  }

  .tag-section__header {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .tag-section__header h2 {
    font-size: clamp(1rem, 0.9rem + 0.4vw, 1.2rem);
    margin: 0;
  }
</style>
