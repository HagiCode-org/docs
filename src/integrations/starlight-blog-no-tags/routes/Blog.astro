---
import type { InferGetStaticPropsType } from 'astro';

import Page from '../../../../node_modules/starlight-blog/components/Page.astro';
import PrevNextLinks from '../../../../node_modules/starlight-blog/components/PrevNextLinks.astro';
import { getPageProps } from '../../../../node_modules/starlight-blog/libs/page.ts';
import { getBlogTitle } from '../../../../node_modules/starlight-blog/libs/title.ts';
import { getBlogStaticPaths } from '../libs/content';
import Posts from '../components/Posts.astro';

export const prerender = true;

export function getStaticPaths() {
  return getBlogStaticPaths();
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { entries, locale, nextLink, prevLink } = Astro.props;

const pageProps = getPageProps(getBlogTitle(locale));
---

<Page {...pageProps}>
  <Posts {entries} {locale} />
  <footer class="not-content">
    <PrevNextLinks next={nextLink} prev={prevLink} />
  </footer>
</Page>

<style>
  :global(.content-panel:first-of-type) {
    display: none;
  }

  :global(.content-panel:nth-of-type(2)) {
    border-top: none;
  }
</style>
