---
import { Markdown } from 'astro-remote';

import type { StarlightBlogEntry } from '../../../../node_modules/starlight-blog/libs/content.ts';
import { resolveBlogEntryExcerpt } from './excerpt-utils.mjs';

interface Props {
  entry: StarlightBlogEntry;
}

const { entry } = Astro.props;
const excerpt = resolveBlogEntryExcerpt(entry);
---

{excerpt && <Markdown content={excerpt} />}

