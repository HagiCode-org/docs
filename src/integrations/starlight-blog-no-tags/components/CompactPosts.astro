---
import type { StarlightBlogEntry } from '../../../../node_modules/starlight-blog/libs/content.ts';
import type { Locale } from '../../../../node_modules/starlight-blog/libs/i18n.ts';
import {
  getPathWithLocale,
  getRelativeUrl,
} from '../../../../node_modules/starlight-blog/libs/page.ts';

interface Props {
  entries: StarlightBlogEntry[];
  locale: Locale;
  showDate?: boolean;
}

const { entries, locale, showDate = true } = Astro.props;
---

<ul class="compact-posts" data-pagefind-ignore>
  {entries.map((entry) => (
    <li class:list={['compact-posts__item', !showDate && 'compact-posts__item--link-only']}>
      <a class="compact-posts__link" href={getRelativeUrl(`/${getPathWithLocale(entry.id, locale)}`)}>
        {entry.data.title}
      </a>
      {
        showDate ? (
          <time class="compact-posts__date" datetime={entry.data.date.toISOString()}>
            {Astro.locals.t('starlightBlog.post.date', { date: entry.data.date })}
          </time>
        ) : null
      }
    </li>
  ))}
</ul>

<style>
  .compact-posts {
    display: grid;
    gap: 0.875rem;
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .compact-posts__item {
    align-items: baseline;
    border-bottom: 1px solid var(--sl-color-gray-6);
    display: grid;
    gap: 0.35rem;
    padding-bottom: 0.875rem;
  }

  .compact-posts__item--link-only {
    border-bottom-style: dashed;
  }

  .compact-posts__link {
    color: var(--sl-color-white);
    font-size: var(--sl-text-base);
    font-weight: 600;
    text-decoration: none;
  }

  .compact-posts__link:hover {
    color: var(--sl-color-text-accent);
  }

  .compact-posts__date {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
  }

  @media (min-width: 50rem) {
    .compact-posts__item {
      column-gap: 1rem;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .compact-posts__item--link-only {
      grid-template-columns: minmax(0, 1fr);
    }

    .compact-posts__date {
      text-align: right;
      white-space: nowrap;
    }
  }
</style>
