---
import GoogleAnalytics from '../../components/GoogleAnalytics.astro';
import {
  buildDocsRoutePath,
  DOCS_LOCALE_METADATA,
  type DocsLocale,
} from '../../lib/i18n';

type RedirectEntryProps = {
  locale: Exclude<DocsLocale, 'root'>;
  htmlLang: string;
  label: string;
  redirectPath: string;
};

export function getStaticPaths() {
  return DOCS_LOCALE_METADATA
      .filter(
        (locale): locale is (typeof DOCS_LOCALE_METADATA)[number] & {
          code: Exclude<DocsLocale, 'root'>;
        } => locale.code !== 'root',
      )
    .map((locale) => ({
      params: { locale: locale.code },
      props: {
        locale: locale.code,
        htmlLang: locale.htmlLang,
        label: locale.label,
        redirectPath: buildDocsRoutePath(locale.code, '/product-overview/'),
      } satisfies RedirectEntryProps,
    }));
}

const { htmlLang, label, redirectPath } = Astro.props as RedirectEntryProps;
const title = 'Redirecting to HagiCode Docs';
const description = `Redirecting to the ${label} HagiCode product overview page.`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta http-equiv="refresh" content={`0;url=${redirectPath}`} />
    <script is:inline define:vars={{ redirectPath }}>
      const currentUrl = new URL(window.location.href);
      const targetUrl = new URL(redirectPath, currentUrl.origin);

      currentUrl.searchParams.forEach((value, key) => {
        targetUrl.searchParams.set(key, value);
      });
      targetUrl.hash = currentUrl.hash;

      window.location.replace(targetUrl.toString());
    </script>
    <GoogleAnalytics />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <noscript>
      <p><a href={redirectPath}>Continue to the HagiCode product overview</a></p>
    </noscript>
  </body>
</html>
