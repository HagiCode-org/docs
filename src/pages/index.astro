---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { DEFAULT_DOCS_ENTRY_LOCALE } from '../lib/i18n';

const language = 'zh-CN';
const title = 'Redirecting to HagiCode Docs';
const description = '正在跳转到 HagiCode 产品概览页面。';
const fallbackTargetPath = '/en/product-overview/';
const landingTargetPath = '/product-overview/';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang={language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="hagicode-docs-default-entry" content={DEFAULT_DOCS_ENTRY_LOCALE} />
    <meta name="hagicode-docs-landing-locale" content="root" />
    <meta name="hagicode-docs-landing-target" content={landingTargetPath} />
    <meta http-equiv="refresh" content={`0;url=${fallbackTargetPath}`} />
    <script is:inline src="/lang-redirect.js"></script>
    <GoogleAnalytics />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <noscript>
      <p><a href={fallbackTargetPath}>继续前往 HagiCode 产品概览</a></p>
    </noscript>
  </body>
</html>
