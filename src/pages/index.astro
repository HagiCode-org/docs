---
/**
 * Docs root landing shell.
 *
 * The Chinese landing remains available on `/`. On first visit, the client-side
 * resolver checks the browser language before deciding whether `/` should stay
 * Chinese or redirect to `/en/`.
 */
import Hero from '../components/Hero.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { DEFAULT_DOCS_ENTRY_LOCALE } from '../lib/i18n';

// Chinese landing metadata used when `/` resolves to the Chinese entry.
const language = 'zh-CN';
const title = 'Hagicode - 智能 AI 编程助手';
const description = '让 AI 帮助你编写更好的代码。多轮对话、代码审查、自动生成、智能调试，全方位提升开发效率。';
const image = '/og-image.png';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Open Graph 配置
const ogTitle = title;
const ogDescription = description;
const ogImage = image;
const ogUrl = canonicalURL.href;

// Chinese CTA remains unchanged for explicit zh-CN landing visits.
const targetPath = '/product-overview/';
const heroTitle = 'Hagicode';
const heroSubtitle = '智能 AI 编程助手，让代码更简单';
const heroDescription = '多轮对话 | 代码审查 | 自动生成 | 智能调试';
const heroCtaText = '开始探索';
---

<!doctype html>
<html lang={language} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="hagicode-docs-default-entry" content={DEFAULT_DOCS_ENTRY_LOCALE} />
    <meta name="hagicode-docs-landing-locale" content="root" />
    <!-- Resolve landing entry before the page becomes interactive. -->
    <script is:inline src="/lang-redirect.js"></script>
    <GoogleAnalytics />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700&family=Rajdhani:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="hero-page">
      <Hero
        title={heroTitle}
        titleEn={heroTitle}
        subtitle={heroSubtitle}
        subtitleEn={heroSubtitle}
        description={heroDescription}
        descriptionEn={heroDescription}
        ctaText={heroCtaText}
        ctaTextEn={heroCtaText}
        targetPath={targetPath}
        lang="zh-CN"
      />
    </main>

    <!-- 结构化数据 -->
    <script type="application/ld+json">
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Hagicode',
        url: 'https://docs.hagicode.com',
        description: description,
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://docs.hagicode.com/search?q={search_term_string}',
          'query-input': 'required name=search_term_string',
        },
      })}
    </script>
  </body>
</html>

<style is:global>
  /* 基础重置 */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Hagicode Dark Theme Variables */
  :root {
    --bg-primary: #020617;
    --bg-secondary: #0F172A;
    --bg-tertiary: #1E293B;
    --text-primary: #F8FAFC;
    --text-secondary: #94A3B8;
    --text-muted: #64748B;
    --accent-primary: #22C55E;
    --accent-hover: #16A34A;
    --blue-primary: #3B82F6;
    --blue-secondary: #60A5FA;
    --border-primary: rgba(148, 163, 184, 0.1);
  }

  html.dark {
    background-color: var(--bg-primary);
  }

  body {
    background-color: var(--bg-primary);
    color: var(--text-primary);
  }

  /* Hero 页面样式 */
  .hero-page {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 媒体查询 - 减少动画 */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
