---
import fs from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

import GoogleAnalytics from '../../components/GoogleAnalytics.astro';

type LegacyEnglishRouteProps = {
  redirectPath: string;
};

export async function getStaticPaths() {
  const docsRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '../../..');
  const englishDocsRoot = path.join(docsRoot, 'src/content/docs/en-US');

  const collectLegacyEnglishRoutes = async (
    directoryPath: string,
    prefix = '',
  ): Promise<string[]> => {
    const entries = await fs.readdir(directoryPath, { withFileTypes: true });
    const routes: string[] = [];

    for (const entry of entries) {
      const entryPath = path.join(directoryPath, entry.name);
      const relativeName = prefix ? `${prefix}/${entry.name}` : entry.name;

      if (entry.isDirectory()) {
        routes.push(...(await collectLegacyEnglishRoutes(entryPath, relativeName)));
        continue;
      }

      if (!entry.isFile() || !entry.name.endsWith('.mdx')) {
        continue;
      }

      const withoutExtension = relativeName.replace(/\.mdx$/u, '');
      const normalizedRoute = withoutExtension.endsWith('/index')
        ? withoutExtension.slice(0, -'/index'.length)
        : withoutExtension;

      routes.push(normalizedRoute);
    }

    return routes;
  };

  const routes = await collectLegacyEnglishRoutes(englishDocsRoot);

  return routes
    .filter((route) => route.length > 0)
    .sort((left, right) => left.localeCompare(right))
    .map((route) => ({
      params: {
        slug: route,
      },
      props: {
        redirectPath: `/en-US/${route}/`,
      } satisfies LegacyEnglishRouteProps,
    }));
}

const { redirectPath } = Astro.props as LegacyEnglishRouteProps;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting to HagiCode Docs</title>
    <meta name="description" content="Redirecting to the canonical English (United States) HagiCode docs page." />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta http-equiv="refresh" content={`0;url=${redirectPath}`} />
    <script is:inline define:vars={{ redirectPath }}>
      const currentUrl = new URL(window.location.href);
      const targetUrl = new URL(redirectPath, currentUrl.origin);

      currentUrl.searchParams.forEach((value, key) => {
        targetUrl.searchParams.set(key, value);
      });
      targetUrl.hash = currentUrl.hash;

      window.location.replace(targetUrl.toString());
    </script>
    <GoogleAnalytics />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <noscript>
      <p><a href={redirectPath}>Continue to the canonical English docs page</a></p>
    </noscript>
  </body>
</html>
