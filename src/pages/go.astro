---
import { TRAFFIC_ENTRY_ROUTE_PATH } from '../lib/traffic-entry.mjs';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Redirecting to HagiCode Docs</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f3efe7;
        --panel: rgba(255, 252, 245, 0.92);
        --text: #1f2d2f;
        --muted: #5a6d6b;
        --accent: #b54b33;
        --border: rgba(31, 45, 47, 0.12);
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: 'Noto Serif SC', 'Source Han Serif SC', serif;
        background:
          radial-gradient(circle at top, rgba(181, 75, 51, 0.18), transparent 35%),
          linear-gradient(135deg, #efe6d2 0%, var(--bg) 45%, #dfe8e5 100%);
        color: var(--text);
      }

      main {
        width: min(36rem, calc(100vw - 2rem));
        padding: 2rem;
        border: 1px solid var(--border);
        border-radius: 24px;
        background: var(--panel);
        box-shadow: 0 24px 80px rgba(31, 45, 47, 0.14);
      }

      h1 {
        margin: 0 0 0.75rem;
        font-size: clamp(2rem, 4vw, 2.8rem);
        line-height: 1.05;
      }

      p {
        margin: 0;
        line-height: 1.7;
        color: var(--muted);
      }

      code {
        color: var(--accent);
        font-size: 0.95em;
      }

      .status {
        margin-top: 1rem;
      }
    </style>
  </head>
  <body>
    <main>
      <p>HagiCode Docs Traffic Entry</p>
      <h1>正在跳转到文档正文</h1>
      <p id="message">
        正在检查 <code>{TRAFFIC_ENTRY_ROUTE_PATH}</code> 的平台与目标参数，请稍候。
      </p>
      <p class="status" id="status">如果未自动跳转，请检查链接参数是否完整。</p>
      <noscript>
        <p class="status">当前入口页需要浏览器 JavaScript 才能在静态预览环境中完成跳转。</p>
      </noscript>
    </main>

    <script type="module">
      import { resolveTrafficEntryRequest } from '/src/lib/traffic-entry.mjs';

      const message = document.getElementById('message');
      const status = document.getElementById('status');
      const resolution = resolveTrafficEntryRequest(new URL(window.location.href));

      if (!resolution.hasTrafficEntryParams) {
        message.textContent = '缺少流量入口参数。';
        status.textContent = '请确认链接中包含 platform 与 target。';
      } else if (!resolution.valid) {
        message.textContent = '流量入口参数无效。';
        status.textContent = resolution.message;
      } else {
        message.textContent = `平台 ${resolution.platformId} 正在跳转到 ${resolution.targetPath}`;
        status.textContent = '如果页面未自动跳转，浏览器将保留这条信息用于本地调试。';
        window.location.replace(resolution.redirectUrl);
      }
    </script>
  </body>
</html>
