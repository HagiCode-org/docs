---
interface ChangelogCommit {
  hash: string;
  title: string;
  detail: string;
  committedAt: string;
}

interface ChangelogRelease {
  tag: string;
  previousTag: string;
  tagDate: string;
  commitCount: number;
  commits: ChangelogCommit[];
}

interface RepoChangelogData {
  repoKey: string;
  repoPath: string;
  generatedAt: string;
  releases: ChangelogRelease[];
}

interface Props {
  data: RepoChangelogData;
  locale?: 'zh-CN' | 'en';
  repoLabel: string;
}

const { data, locale = 'zh-CN', repoLabel } = Astro.props;

const isEnglish = locale === 'en';
const releaseOptions = data.releases.map((release) => release.tag);
const labels = isEnglish
  ? {
      overview:
        'Generated from adjacent Git tag windows. Each release block shows the commits collected from previousTag..tag.',
      repoKey: 'Repository key',
      repoPath: 'Source repository',
      generatedAt: 'Generated at',
      releaseCount: 'Release blocks',
      previousTag: 'Previous tag',
      tagDate: 'Tag date',
      commitCount: 'Commit count',
      detailFallback: 'No detail provided for this commit.',
      releaseEmpty: 'No commits were collected for this tag window.',
      emptyTitle: 'No adjacent-tag releases yet',
      emptyBody:
        'This dataset has fewer than two tags, so the changelog remains a valid empty release list.',
      commitHash: 'Commit',
      filterLabel: 'Jump to release',
      filterHint: 'Select a tag to focus on a single release block.',
      filterAll: 'All releases',
      filterStatus: (visible: number, total: number) => `Showing ${visible} of ${total} release blocks`,
      filterEmpty: 'No release block matches the current tag filter.',
    }
  : {
      overview: '此页按相邻 Git tag 区间自动生成。每个版本区块对应一次 `previousTag..tag` 提交采集结果。',
      repoKey: '仓库键',
      repoPath: '来源仓库',
      generatedAt: '生成时间',
      releaseCount: '版本区块数',
      previousTag: '前置 Tag',
      tagDate: 'Tag 时间',
      commitCount: '提交数',
      detailFallback: '此提交无额外详情。',
      releaseEmpty: '此 Tag 区间未采集到提交。',
      emptyTitle: '暂无可渲染的相邻 Tag 版本',
      emptyBody: '当前数据集少于两个 tag，故仅保留合法空 `releases` 结果。',
      commitHash: '提交',
      filterLabel: '版本筛选',
      filterHint: '可直接选择某个 Tag，仅查看该版本区块。',
      filterAll: '全部版本',
      filterStatus: (visible: number, total: number) => `当前显示 ${visible}/${total} 个版本区块`,
      filterEmpty: '当前筛选条件下无可显示的版本区块。',
    };

function shortHash(value: string) {
  return value.slice(0, 7);
}

function getCanonicalReleaseAnchor(value: string) {
  const normalizedValue = value.trim().replace(/^#/, '').toLowerCase().replace(/^v+/, '');
  return normalizedValue.length === 0 ? '' : `v${normalizedValue}`;
}
---

<section class="repo-changelog" data-repo-changelog>
  <div class="repo-summary" data-changelog-summary>
    <p class="repo-name">{repoLabel}</p>
    <p class="overview">{labels.overview}</p>
    {
      data.releases.length > 0 && (
        <div
          class="release-filter-panel"
          data-release-filter-root
          data-filter-empty-label={labels.filterEmpty}
          data-filter-status-template={labels.filterStatus(0, data.releases.length)}
        >
          <div class="release-filter-copy">
            <p class="filter-label">{labels.filterLabel}</p>
            <p class="filter-hint">{labels.filterHint}</p>
          </div>
          <div class="release-filter-controls">
            <label class="sr-only" for={`release-filter-${data.repoKey}`}>
              {labels.filterLabel}
            </label>
            <select id={`release-filter-${data.repoKey}`} class="release-filter-select" data-release-filter-select>
              <option value="">{labels.filterAll}</option>
              {releaseOptions.map((tag) => (
                <option value={tag}>{tag}</option>
              ))}
            </select>
            <p class="filter-status" data-release-filter-status>
              {labels.filterStatus(data.releases.length, data.releases.length)}
            </p>
          </div>
        </div>
      )
    }
    <dl class="meta-grid">
      <div>
        <dt>{labels.repoKey}</dt>
        <dd>{data.repoKey}</dd>
      </div>
      <div>
        <dt>{labels.repoPath}</dt>
        <dd><code>{data.repoPath}</code></dd>
      </div>
      <div>
        <dt>{labels.generatedAt}</dt>
        <dd><time datetime={data.generatedAt}>{data.generatedAt}</time></dd>
      </div>
      <div>
        <dt>{labels.releaseCount}</dt>
        <dd>{data.releases.length}</dd>
      </div>
    </dl>
  </div>

  {
    data.releases.length === 0 ? (
      <div class="empty-state" data-changelog-empty>
        <p class="empty-title">{labels.emptyTitle}</p>
        <p class="empty-body">{labels.emptyBody}</p>
      </div>
    ) : (
      <div class="release-list">
        {data.releases.map((release) => (
          <article
            id={getCanonicalReleaseAnchor(release.tag)}
            class="release-card"
            tabindex="-1"
            data-release-block
            data-release-tag-value={release.tag}
            data-release-anchor-value={getCanonicalReleaseAnchor(release.tag)}
          >
            <div class="release-header">
              <div>
                <p class="release-tag" data-release-tag>{release.tag}</p>
                <p class="release-meta-line">
                  <span>{labels.previousTag}: </span>
                  <code>{release.previousTag}</code>
                </p>
              </div>
              <dl class="release-meta">
                <div>
                  <dt>{labels.tagDate}</dt>
                  <dd>
                    <time datetime={release.tagDate}>{release.tagDate}</time>
                  </dd>
                </div>
                <div>
                  <dt>{labels.commitCount}</dt>
                  <dd>{release.commitCount}</dd>
                </div>
              </dl>
            </div>

            {
              release.commits.length === 0 ? (
                <p class="release-empty">{labels.releaseEmpty}</p>
              ) : (
                <ol class="commit-list">
                  {release.commits.map((commit) => (
                    <li class="commit-item" data-commit-item>
                      <div class="commit-heading">
                        <p class="commit-title">{commit.title}</p>
                        <p class="commit-hash">
                          <span>{labels.commitHash}: </span>
                          <code>{shortHash(commit.hash)}</code>
                        </p>
                      </div>
                      <p class="commit-time">
                        <time datetime={commit.committedAt}>{commit.committedAt}</time>
                      </p>
                      <p class:list={['commit-detail', { 'is-empty': commit.detail.length === 0 }]}>
                        {commit.detail || labels.detailFallback}
                      </p>
                    </li>
                  ))}
                </ol>
              )
            }
          </article>
        ))}
      </div>
    )
  }

  {
    data.releases.length > 0 && (
      <div class="empty-state filter-empty-state" data-release-filter-empty hidden>
        <p class="empty-title">{labels.filterEmpty}</p>
      </div>
    )
  }
</section>

{
  data.releases.length > 0 && (
    <script is:inline>
      (() => {
        const root = document.currentScript?.previousElementSibling;
        if (!(root instanceof HTMLElement)) {
          return;
        }

        const select = root.querySelector('[data-release-filter-select]');
        const status = root.querySelector('[data-release-filter-status]');
        const emptyState = root.querySelector('[data-release-filter-empty]');
        const cards = Array.from(root.querySelectorAll('[data-release-block]'));
        const total = cards.length;
        const emptyLabel = root.querySelector('[data-release-filter-root]')?.getAttribute('data-filter-empty-label') ?? '';

        if (!(select instanceof HTMLSelectElement) || !(status instanceof HTMLElement)) {
          return;
        }

        const getCanonicalAnchor = (value) => {
          const normalizedValue = value.trim().replace(/^#/, '').toLowerCase().replace(/^v+/, '');
          return normalizedValue.length === 0 ? '' : `v${normalizedValue}`;
        };

        const hasTag = (tag) =>
          tag.length === 0 || cards.some((card) => card.getAttribute('data-release-tag-value') === tag);

        const findCardByHash = (hashValue) => {
          const normalizedHash = getCanonicalAnchor(hashValue);
          if (normalizedHash.length === 0) {
            return null;
          }

          return (
            cards.find((card) => card.getAttribute('data-release-anchor-value') === normalizedHash) ?? null
          );
        };

        const updateStatus = (visibleCount) => {
          status.textContent =
            select.value.length === 0
              ? `${visibleCount}/${total}`
              : `${select.value} · ${visibleCount}/${total}`;
        };

        const applyFilter = (tag, shouldSyncUrl) => {
          let visibleCount = 0;
          let firstMatchedCard = null;

          for (const card of cards) {
            const matched = tag.length === 0 || card.getAttribute('data-release-tag-value') === tag;
            card.toggleAttribute('hidden', !matched);
            if (matched) {
              visibleCount += 1;
              if (firstMatchedCard === null) {
                firstMatchedCard = card;
              }
            }
          }

          updateStatus(visibleCount);

          if (emptyState instanceof HTMLElement) {
            emptyState.toggleAttribute('hidden', visibleCount !== 0);
          }

          if (shouldSyncUrl) {
            const url = new URL(window.location.href);
            if (tag.length === 0) {
              url.searchParams.delete('tag');
              url.hash = '';
            } else {
              url.searchParams.set('tag', tag);
              url.hash = firstMatchedCard?.getAttribute('data-release-anchor-value') ?? '';
            }
            window.history.replaceState({}, '', url);
          }

          if (visibleCount === 0 && emptyState instanceof HTMLElement) {
            const title = emptyState.querySelector('.empty-title');
            if (title instanceof HTMLElement) {
              title.textContent = emptyLabel;
            }
          }

          return firstMatchedCard;
        };

        const focusReleaseCard = (card) => {
          if (!(card instanceof HTMLElement)) {
            return;
          }

          window.requestAnimationFrame(() => {
            card.scrollIntoView({ block: 'start', behavior: 'auto' });
            card.focus({ preventScroll: true });
          });
        };

        const initialUrl = new URL(window.location.href);
        const initialTag = initialUrl.searchParams.get('tag') ?? '';
        const initialHashMatch = findCardByHash(window.location.hash);

        if (initialHashMatch) {
          const matchedTag = initialHashMatch.getAttribute('data-release-tag-value') ?? '';
          if (hasTag(matchedTag)) {
            select.value = matchedTag;
          }
        } else if (hasTag(initialTag)) {
          select.value = initialTag;
        }

        const initialVisibleCard = applyFilter(select.value, false);
        if (initialHashMatch instanceof HTMLElement) {
          focusReleaseCard(initialHashMatch);
        } else if (initialVisibleCard instanceof HTMLElement && select.value.length > 0) {
          focusReleaseCard(initialVisibleCard);
        }

        select.addEventListener('change', () => applyFilter(select.value, true));
      })();
    </script>
  )
}

<style>
  .repo-changelog {
    --repo-surface: linear-gradient(180deg, rgb(255 255 255 / 0.96), rgb(246 249 252 / 0.94));
    --repo-surface-strong: linear-gradient(180deg, rgb(248 250 252 / 0.95), rgb(237 242 247 / 0.92));
    --repo-surface-soft: rgb(255 255 255 / 0.78);
    --repo-border: rgb(148 163 184 / 0.22);
    --repo-border-strong: rgb(59 130 246 / 0.22);
    --repo-shadow: 0 20px 48px rgb(15 23 42 / 0.08);
    --repo-text-muted: rgb(71 85 105 / 0.96);
    --repo-text-subtle: rgb(100 116 139 / 0.94);
    --repo-accent: rgb(14 116 144 / 1);
    --repo-accent-soft: rgb(14 116 144 / 0.1);
    --repo-filter-ring: rgb(14 116 144 / 0.18);
    display: grid;
    gap: 1.5rem;
  }

  :global(html[data-theme='dark']) .repo-changelog {
    --repo-surface: linear-gradient(180deg, rgb(12 19 34 / 0.96), rgb(5 11 24 / 0.98));
    --repo-surface-strong: linear-gradient(180deg, rgb(20 31 50 / 0.9), rgb(8 16 30 / 0.92));
    --repo-surface-soft: rgb(15 23 42 / 0.78);
    --repo-border: rgb(148 163 184 / 0.18);
    --repo-border-strong: rgb(56 189 248 / 0.26);
    --repo-shadow: 0 24px 56px rgb(2 6 23 / 0.42);
    --repo-text-muted: rgb(226 232 240 / 0.96);
    --repo-text-subtle: rgb(148 163 184 / 0.92);
    --repo-accent: rgb(103 232 249 / 0.96);
    --repo-accent-soft: rgb(34 211 238 / 0.14);
    --repo-filter-ring: rgb(34 211 238 / 0.24);
  }

  .repo-summary,
  .empty-state,
  .release-card {
    border: 1px solid var(--repo-border);
    border-radius: 1rem;
    background: var(--repo-surface);
    box-shadow: var(--repo-shadow);
  }

  .repo-summary,
  .empty-state {
    padding: 1.25rem;
  }

  .overview {
    margin: 0;
    color: var(--repo-text-muted);
    line-height: 1.7;
  }

  .repo-name {
    margin: 0 0 0.6rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--repo-accent);
    letter-spacing: 0.01em;
  }

  .release-filter-panel {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid var(--repo-border-strong);
    border-radius: 1rem;
    background:
      linear-gradient(135deg, var(--repo-accent-soft), transparent 58%),
      var(--repo-surface-strong);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.08);
  }

  .release-filter-copy,
  .release-filter-controls {
    display: grid;
    gap: 0.35rem;
  }

  .filter-label,
  .filter-status {
    margin: 0;
  }

  .filter-label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--repo-accent);
  }

  .filter-hint {
    margin: 0;
    color: var(--repo-text-subtle);
    line-height: 1.65;
  }

  .release-filter-select {
    width: 100%;
    min-height: 3rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid var(--repo-border-strong);
    border-radius: 0.85rem;
    background: var(--repo-surface-soft);
    color: var(--sl-color-text);
    font: inherit;
    box-shadow: 0 0 0 0 var(--repo-filter-ring);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .release-filter-select:hover {
    transform: translateY(-1px);
  }

  .release-filter-select:focus-visible {
    outline: none;
    border-color: var(--repo-accent);
    box-shadow: 0 0 0 0.3rem var(--repo-filter-ring);
  }

  .filter-status {
    color: var(--repo-text-subtle);
    font-variant-numeric: tabular-nums;
  }

  .meta-grid,
  .release-meta {
    display: grid;
    gap: 0.9rem;
    margin: 1rem 0 0;
  }

  .meta-grid {
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
  }

  .meta-grid div,
  .release-meta div {
    padding: 0.85rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid rgb(148 163 184 / 0.12);
    background: var(--repo-surface-strong);
  }

  dt {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--repo-text-subtle);
  }

  dd {
    margin: 0.35rem 0 0;
    color: var(--sl-color-text);
    word-break: break-word;
  }

  .release-list {
    display: grid;
    gap: 1rem;
  }

  .release-card {
    padding: 1.15rem;
    scroll-margin-top: clamp(5.5rem, 14vh, 8rem);
  }

  .release-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .release-tag {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--repo-accent);
  }

  .release-meta-line,
  .commit-time,
  .commit-hash {
    margin: 0.35rem 0 0;
    color: var(--repo-text-subtle);
    font-size: 0.92rem;
  }

  .commit-list {
    display: grid;
    gap: 0.85rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .commit-item {
    padding: 1rem;
    border-radius: 0.9rem;
    border: 1px solid var(--repo-border);
    background: var(--repo-surface-soft);
  }

  .commit-heading {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
    justify-content: space-between;
  }

  .commit-title {
    margin: 0;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .commit-detail {
    margin: 0.65rem 0 0;
    line-height: 1.7;
    color: var(--repo-text-muted);
    white-space: pre-wrap;
  }

  .commit-detail.is-empty {
    font-style: italic;
    color: var(--repo-text-subtle);
  }

  .empty-title {
    margin: 0;
    font-weight: 700;
    color: var(--sl-color-text);
  }

  .filter-empty-state[hidden] {
    display: none;
  }

  .release-empty,
  .empty-body {
    margin: 0.6rem 0 0;
    color: var(--repo-text-subtle);
    line-height: 1.7;
  }

  @media (min-width: 50rem) {
    .release-filter-panel {
      grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 1fr);
      align-items: end;
    }

    .release-header {
      grid-template-columns: minmax(0, 1.6fr) minmax(16rem, 1fr);
      align-items: start;
    }
  }
</style>
