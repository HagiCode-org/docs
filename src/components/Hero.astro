  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.25rem;
    width: 100%;
    padding: 0 0.5rem;
  }

  @media (min-width: 480px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
