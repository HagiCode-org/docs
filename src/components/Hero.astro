---
/**
 * Hero 组件 - Cyberpunk Futuristic Style
 *
 * Hagicode AI 编程助手 - 赛博朋克科技风格
 * 整个页面可点击导航到 /product-overview
 * 包含: 粒子背景、流光效果、鼠标跟随、霓虹CTA、故障效果
 * 支持中英文双语显示
 */
const {
  title = "Hagicode",
  titleEn = "Hagicode",
  subtitle = "智能 AI 编程助手，让代码更简单",
  subtitleEn = "Smart AI Programming Assistant - Make Coding Easier",
  description = "多轮对话 | 代码审查 | 自动生成 | 智能调试",
  descriptionEn = "Multi-turn conversations | Code review | Auto generation | Intelligent debugging",
  ctaText = "开始探索",
  ctaTextEn = "Start Exploring",
  targetPath = "/product-overview",
  lang = "zh-CN",
} = Astro.props;

const features = [
  { icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z", title: "提案驱动", titleEn: "Proposal-Driven", desc: "将想法转化为结构化实施计划，先规划后实施", descEn: "Transform ideas into structured implementation plans, plan before execute" },
  { icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0zm0 0v1a3 3 0 11-6 0v-1m6 0H9m3 0a3 3 0 11-6 0m6 0H9", title: "双模式", titleEn: "Dual Mode", desc: "只读/编辑双模式，细粒度权限控制", descEn: "Read/Edit dual mode with fine-grained permission control" },
  { icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z", title: "深度理解", titleEn: "Deep Understanding", desc: "超越代码生成，真正理解项目架构", descEn: "Go beyond code generation, truly understand project architecture" },
  { icon: "M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1 1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1 1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1 1v-6z", title: "自举特性", titleEn: "Bootstrapping", desc: "用自己的技术栈构建，验证实用性", descEn: "Build with your own tech stack, verify practicality" },
];

// Determine if we should use English text based on explicit lang prop
const useEnglish = lang === 'en';
---
<section class="hero-container" role="main" aria-label="首页介绍" tabindex="0">
  <!-- 粒子背景 Canvas -->
  <canvas id="particles-canvas" class="particles-canvas" aria-hidden="true"></canvas>

  <!-- 扫描线效果 -->
  <div class="scanlines" aria-hidden="true"></div>

  <!-- 径向渐变光晕 -->
  <div class="glow-container">
    <div class="glow-orb glow-orb-1"></div>
    <div class="glow-orb glow-orb-2"></div>
    <div class="glow-orb glow-orb-3"></div>
  </div>

  <!-- 网格背景 -->
  <div class="grid-overlay" aria-hidden="true"></div>

  <!-- 鼠标跟随光点 -->
  <div class="cursor-follower" aria-hidden="true"></div>

  <div class="hero-content">
    <header class="hero-header">
      <!-- 装饰性角落元素 -->
      <div class="corner-element top-left"></div>
      <div class="corner-element top-right"></div>
      <div class="corner-element bottom-left"></div>
      <div class="corner-element bottom-right"></div>

      <div class="logo-badge">
        <span class="badge-dot"></span>
        <span>AI Powered</span>
      </div>

      <h1 class="hero-title" aria-label={title}>
        <span class="title-text" data-text={title}>{title}</span>
        <span class="title-glitch" aria-hidden="true">
          <span class="glitch-layer" data-text={title}></span>
          <span class="glitch-layer" data-text={title}></span>
        </span>
      </h1>

      <p class="hero-subtitle">
        <span class="typing-text">{subtitle}</span>
      </p>
    </header>

    <div class="cta-wrapper">
      <button class="cta-button" aria-label={ctaText}>
        <span class="cta-content">
          <span class="cta-text">{ctaText}</span>
          <span class="cta-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </span>
        <span class="cta-glow"></span>
        <span class="cta-border"></span>
        <!-- 装饰性粒子 -->
        <span class="cta-particles">
          {[...Array(8)].map((_, i) => (
            <span class="particle" style={`--i: ${i}`}></span>
          ))}
        </span>
      </button>
      <p class="hint-text">
        <span class="hint-icon">◈</span>
        <span class="hint-arrow">→</span>
      </p>
    </div>

    <section class="features-grid" aria-label="产品特性">
      {
        features.map((feature, index) => (
          <article
            class="feature-card"
            style={`--delay: ${index * 120}ms`}
            aria-label={useEnglish ? feature.titleEn : feature.title}
            tabindex="0"
          >
            <div class="card-bg-effect"></div>
            <div class="feature-icon-wrapper">
              <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={feature.icon} />
              </svg>
            </div>
            <div class="feature-content">
              <h2 class="feature-title">{useEnglish ? feature.titleEn : feature.title}</h2>
              <p class="feature-desc">{useEnglish ? feature.descEn : feature.desc}</p>
            </div>
            <div class="card-corner-accents">
              <span class="corner corner-tl"></span>
              <span class="corner corner-tr"></span>
              <span class="corner corner-bl"></span>
              <span class="corner corner-br"></span>
            </div>
          </article>
        ))
      }
    </section>
  </div>

  <!-- 底部装饰线 -->
  <div class="bottom-decor">
    <div class="progress-line"></div>
  </div>
</section>

<style is:global>
  /* CSS Variables - Cyberpunk Theme */
  :root {
    /* Background */
    --bg-primary: #030712;
    --bg-secondary: #0F172A;
    --bg-tertiary: #1E293B;
    --bg-glass: rgba(17, 24, 39, 0.4);

    /* Text */
    --text-primary: #F8FAFC;
    --text-secondary: #94A3B8;
    --text-muted: #64748B;

    /* Accent - Cyber Green */
    --accent-primary: #10B981;
    --accent-hover: #34D399;
    --accent-glow: rgba(16, 185, 129, 0.4);
    --accent-dim: rgba(16, 185, 129, 0.15);

    /* Neon Accents */
    --neon-cyan: #06B6D4;
    --neon-blue: #3B82F6;
    --neon-purple: #8B5CF6;
    --neon-pink: #EC4899;

    /* Borders */
    --border-primary: rgba(16, 185, 129, 0.15);
    --border-hover: rgba(16, 185, 129, 0.4);
    --border-glow: rgba(16, 185, 129, 0.3);

    /* Effects */
    --glow-primary: rgba(16, 185, 129, 0.2);
    --glow-secondary: rgba(6, 182, 212, 0.15);
    --glow-tertiary: rgba(139, 92, 246, 0.1);

    /* Timing */
    --transition-fast: 150ms;
    --transition-normal: 300ms;
    --transition-slow: 500ms;
  }

  html {
    background-color: var(--bg-primary);
  }

  html.dark {
    background-color: var(--bg-primary);
  }

  body {
    background-color: var(--bg-primary);
    color: var(--text-primary);
    overflow-x: hidden;
  }

  /* Hero 页面样式 */
  .hero-page {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Particles Canvas */
  .particles-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    opacity: 0.6;
  }

  /* Scanlines Overlay */
  .scanlines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.03) 2px,
      rgba(0, 0, 0, 0.03) 4px
    );
    animation: scanlineMove 8s linear infinite;
  }

  @keyframes scanlineMove {
    0% { transform: translateY(0); }
    100% { transform: translateY(4px); }
  }

  /* Glow Orbs */
  .glow-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: orbFloat 15s ease-in-out infinite;
  }

  .glow-orb-1 {
    width: 600px;
    height: 600px;
    background: var(--glow-primary);
    top: -200px;
    right: -100px;
    animation-delay: 0s;
  }

  .glow-orb-2 {
    width: 500px;
    height: 500px;
    background: var(--glow-secondary);
    bottom: -150px;
    left: -100px;
    animation-delay: -5s;
  }

  .glow-orb-3 {
    width: 400px;
    height: 400px;
    background: var(--glow-tertiary);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -10s;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    25% { transform: translate(30px, -30px) scale(1.05); opacity: 0.6; }
    50% { transform: translate(-20px, 20px) scale(0.95); opacity: 0.4; }
    75% { transform: translate(20px, 30px) scale(1.02); opacity: 0.55; }
  }

  /* Grid Overlay */
  .grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    background-image:
      linear-gradient(var(--border-primary) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-primary) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.15;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }

  /* Cursor Follower */
  .cursor-follower {
    position: fixed;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent-dim) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.3s ease;
    transform: translate(-50%, -50%);
    mix-blend-mode: screen;
  }

  .hero-container:hover .cursor-follower {
    opacity: 1;
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    width: 100%;
    text-align: center;
    animation: fadeIn 1s ease-out;
  }

  /* Corner Elements */
  .corner-element {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 2px solid var(--accent-primary);
    opacity: 0.3;
  }

  .corner-element.top-left {
    top: -20px;
    left: -20px;
    border-right: none;
    border-bottom: none;
  }

  .corner-element.top-right {
    top: -20px;
    right: -20px;
    border-left: none;
    border-bottom: none;
  }

  .corner-element.bottom-left {
    bottom: -20px;
    left: -20px;
    border-right: none;
    border-top: none;
  }

  .corner-element.bottom-right {
    bottom: -20px;
    right: -20px;
    border-left: none;
    border-top: none;
  }

  /* Header */
  .hero-header {
    position: relative;
    margin-bottom: 3.5rem;
  }

  /* Logo Badge */
  .logo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid var(--border-primary);
    color: var(--accent-primary);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .logo-badge::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(16, 185, 129, 0.2), transparent);
    animation: badgeShine 3s ease-in-out infinite;
  }

  @keyframes badgeShine {
    0% { left: -100%; }
    50%, 100% { left: 100%; }
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-primary);
    box-shadow: 0 0 10px var(--accent-primary);
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Title */
  .hero-title {
    font-family: 'Orbitron', 'Space Grotesk', sans-serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-primary);
    letter-spacing: 0.05em;
    line-height: 1;
    position: relative;
    display: inline-block;
  }

  .title-text {
    background: linear-gradient(135deg,
      var(--text-primary) 0%,
      var(--accent-primary) 50%,
      var(--neon-cyan) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 6s ease infinite;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Glitch Effect */
  .title-glitch {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    opacity: 0;
  }

  .hero-title:hover .title-glitch {
    opacity: 1;
  }

  .glitch-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: inherit;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .glitch-layer:first-child {
    animation: glitch1 3s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
  }

  .glitch-layer:last-child {
    animation: glitch2 3s infinite linear alternate-reverse;
    clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
  }

  @keyframes glitch1 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(-3px, 3px); }
    40% { transform: translate(-3px, -3px); }
    60% { transform: translate(3px, 3px); }
    80% { transform: translate(3px, 3px); }
  }

  @keyframes glitch2 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(3px, -3px); }
    40% { transform: translate(-3px, 3px); }
    60% { transform: translate(3px, -3px); }
    80% { transform: translate(-3px, -3px); }
  }

  /* Subtitle */
  .hero-subtitle {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 500;
    margin: 0 0 1.5rem 0;
    color: var(--text-secondary);
    line-height: 1.4;
    letter-spacing: 0.1em;
  }

  .typing-text {
    position: relative;
    display: inline-block;
  }

  .typing-text::after {
    content: '|';
    position: absolute;
    right: -0.5em;
    animation: blink 1s step-end infinite;
    color: var(--accent-primary);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Description */
  .hero-description {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem 2rem;
    font-size: clamp(0.875rem, 1.5vw, 1rem);
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  .desc-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
  }

  .desc-line {
    width: 4px;
    height: 4px;
    background: var(--accent-primary);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-primary);
  }

  /* CTA Wrapper */
  .cta-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  /* CTA Button - Cyberpunk Style */
  .cta-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 3rem;
    background: transparent;
    border: none;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cta-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--accent-primary), var(--neon-cyan));
    border-radius: 0.5rem;
    color: var(--bg-primary);
    font-family: 'Rajdhani', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow:
      0 0 20px rgba(16, 185, 129, 0.3),
      0 0 40px rgba(16, 185, 129, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }

  .cta-icon {
    display: flex;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .cta-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .cta-button:hover .cta-content {
    transform: translateY(-2px);
    box-shadow:
      0 0 30px rgba(16, 185, 129, 0.5),
      0 0 60px rgba(16, 185, 129, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .cta-button:hover .cta-icon {
    transform: translateX(4px);
    animation: iconBounce 0.5s ease;
  }

  @keyframes iconBounce {
    0%, 100% { transform: translateX(4px); }
    50% { transform: translateX(8px); }
  }

  /* CTA Glow */
  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120%;
    height: 120%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse, var(--accent-glow) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
    animation: glowPulse 2s ease-in-out infinite;
  }

  .cta-button:hover .cta-glow {
    opacity: 1;
  }

  @keyframes glowPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
    50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.8; }
  }

  /* CTA Border */
  .cta-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 2px solid var(--accent-primary);
    border-radius: 0.5rem;
    opacity: 0.5;
    animation: borderRotate 3s linear infinite;
    z-index: 0;
  }

  @keyframes borderRotate {
    0% { clip-path: polygon(0 0, 20px 0, 20px 2px, 100% 2px, 100% 20px, 98% 20px, 98% 20px); transform: rotate(0deg); }
    25% { clip-path: polygon(0 0, 20px 0, 20px 2px, 100% 2px, 100% 20px, 98% 20px, 98% 100%, 80% 100%, 80% 98px, 0 98px); transform: rotate(0deg); }
    50% { clip-path: polygon(0 0, 20px 0, 20px 2px, 100% 2px, 100% 20px, 98% 20px, 98% 100%, 80% 100%, 80% 98px, 0 98px); transform: rotate(0deg); }
    75% { clip-path: polygon(0 0, 20px 0, 20px 2px, 100% 2px, 100% 20px, 98% 20px, 98% 100%, 80% 100%, 80% 98px, 0 80px, 2% 80px); transform: rotate(0deg); }
    100% { clip-path: polygon(0 80px, 2% 80px, 2% 100%, 0 98px, 98% 100%, 0 98px, 0 98px, 0 98px, 100% 20px); transform: rotate(0deg); }
  }

  /* CTA Particles */
  .cta-particles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--accent-primary);
    border-radius: 50%;
    opacity: 0;
  }

  .cta-button:hover .particle {
    animation: particleExplode 1s ease-out forwards;
  }

  .particle:nth-child(1) { --angle: 0deg; }
  .particle:nth-child(2) { --angle: 45deg; }
  .particle:nth-child(3) { --angle: 90deg; }
  .particle:nth-child(4) { --angle: 135deg; }
  .particle:nth-child(5) { --angle: 180deg; }
  .particle:nth-child(6) { --angle: 225deg; }
  .particle:nth-child(7) { --angle: 270deg; }
  .particle:nth-child(8) { --angle: 315deg; }

  @keyframes particleExplode {
    0% { opacity: 1; transform: translate(-50%, -50%) rotate(var(--angle)) translateY(0); }
    100% { opacity: 0; transform: translate(-50%, -50%) rotate(var(--angle)) translateY(-60px); }
  }

  /* Hint Text */
  .hint-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 400;
    animation: hintPulse 2s ease-in-out infinite;
  }

  .hint-icon {
    color: var(--accent-primary);
    animation: iconSpin 4s linear infinite;
  }

  @keyframes iconSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes hintPulse {
    0%, 100% { opacity: 0.6; }
