---
/**
 * Hero 组件 - Dark Mode (OLED) 风格首页
 *
 * Hagicode AI 编程助手 - 深色科技风格
 * 整个页面可点击导航到 /product-overview
 */
const {
  title = "Hagicode",
  subtitle = "智能 AI 编程助手，让代码更简单",
  description = "多轮对话 | 代码审查 | 自动生成 | 智能调试",
  ctaText = "开始使用",
} = Astro.props;

const features = [
  { icon: "M8 12h.01M21 12h-7m-6 0h-7m12-6H5m14 0h-7M8 12a4 4 0 1 0 0 8 0 4 4 0 0 0 0-8z", title: "多轮对话", desc: "自然语言交互，精准理解需求" },
  { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", title: "代码审查", desc: "智能分析代码质量，提供优化建议" },
  { icon: "M13 10V3L4 14h7v7l9-11h-7z", title: "自动生成", desc: "快速生成高质量代码片段" },
  { icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4", title: "智能调试", desc: "定位并修复错误，提高开发效率" },
];
---

<section class="hero-container" role="main" aria-label="首页介绍" tabindex="0">
  <!-- 渐变背景网格 -->
  <div class="grid-bg" aria-hidden="true"></div>

  <!-- 光晕效果 -->
  <div class="glow-spot glow-primary" aria-hidden="true"></div>
  <div class="glow-spot glow-secondary" aria-hidden="true"></div>

  <div class="hero-content">
    <header class="hero-header">
      <div class="logo-badge">AI Powered</div>
      <h1 class="hero-title" aria-label={title}>
        {title}
      </h1>
      <p class="hero-subtitle">{subtitle}</p>
      <p class="hero-description">{description}</p>
    </header>

    <div class="cta-wrapper">
      <div class="cta-button">
        <span>{ctaText}</span>
        <svg class="cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </div>
      <p class="hint-text">点击任意位置探索更多</p>
    </div>

    <section class="features-grid" aria-label="产品特性">
      {
        features.map((feature, index) => (
          <article
            class="feature-card"
            style={`--delay: ${index * 100}ms`}
            aria-label={feature.title}
            tabindex="0"
          >
            <div class="feature-icon-wrapper">
              <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={feature.icon} />
              </svg>
            </div>
            <h2 class="feature-title">{feature.title}</h2>
            <p class="feature-desc">{feature.desc}</p>
          </article>
        ))
      }
    </section>
  </div>
</section>

<style is:global>
  /* CSS 变量 - Hagicode Dark Theme */
  :root {
    /* Primary - Slate colors */
    --bg-primary: #020617;
    --bg-secondary: #0F172A;
    --bg-tertiary: #1E293B;
    --bg-glass: rgba(15, 23, 42, 0.6);

    /* Text */
    --text-primary: #F8FAFC;
    --text-secondary: #94A3B8;
    --text-muted: #64748B;

    /* Accent - Success Green */
    --accent-primary: #22C55E;
    --accent-hover: #16A34A;
    --accent-glow: rgba(34, 197, 94, 0.3);

    /* Blue Accent */
    --blue-primary: #3B82F6;
    --blue-secondary: #60A5FA;
    --blue-glow: rgba(59, 130, 246, 0.2);

    /* Borders */
    --border-primary: rgba(148, 163, 184, 0.1);
    --border-hover: rgba(148, 163, 184, 0.2);

    /* Effects */
    --glow-primary: rgba(59, 130, 246, 0.15);
    --glow-secondary: rgba(34, 197, 94, 0.1);
  }

  /* Deep dark base */
  html {
    background-color: var(--bg-primary);
  }

  html.dark {
    background-color: var(--bg-primary);
  }

  /* Light mode adaptation */
  html:not(.dark) {
    --bg-primary: #FFFFFF;
    --bg-secondary: #F1F5F9;
    --bg-tertiary: #E2E8F0;
    --bg-glass: rgba(255, 255, 255, 0.8);
    --text-primary: #0F172A;
    --text-secondary: #475569;
    --text-muted: #94A3B8;
    --border-primary: rgba(148, 163, 184, 0.2);
    --border-hover: rgba(148, 163, 184, 0.3);
    --glow-primary: rgba(59, 130, 246, 0.08);
    --glow-secondary: rgba(34, 197, 94, 0.08);
  }
</style>

<style>
  /* Import Google Fonts */
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap');

  /* Base Container */
  .hero-container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 2rem 1rem;
    overflow: hidden;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* Grid Background */
  .grid-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--border-primary) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-primary) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.3;
  }

  /* Glow Spots */
  .glow-spot {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    z-index: 0;
    pointer-events: none;
  }

  .glow-primary {
    width: 500px;
    height: 500px;
    background: var(--glow-primary);
    top: -150px;
    right: -150px;
    opacity: 0.6;
  }

  .glow-secondary {
    width: 400px;
    height: 400px;
    background: var(--glow-secondary);
    bottom: -100px;
    left: -100px;
    opacity: 0.5;
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    text-align: center;
    animation: fadeIn 0.8s ease-out;
  }

  /* Header */
  .hero-header {
    margin-bottom: 3rem;
  }

  .logo-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 1rem;
    border-radius: 2rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    color: var(--accent-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  /* Title */
  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
    background: linear-gradient(135deg,
      var(--text-primary) 0%,
      var(--blue-secondary) 50%,
      var(--accent-primary) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 8s ease infinite;
  }

  .hero-subtitle {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 500;
    margin: 0 0 1rem 0;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .hero-description {
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    font-weight: 400;
    margin: 0;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  /* CTA Wrapper */
  .cta-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    background: var(--accent-primary);
    color: #020617;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow:
      0 4px 6px -1px rgba(34, 197, 94, 0.2),
      0 0 20px rgba(34, 197, 94, 0.15);
  }

  .cta-button:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow:
      0 8px 12px -1px rgba(34, 197, 94, 0.3),
      0 0 30px rgba(34, 197, 94, 0.25);
  }

  .cta-button:active {
    transform: translateY(0);
    transition: all 0.1s ease;
  }

  .cta-arrow {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform 0.2s ease;
  }

  .cta-button:hover .cta-arrow {
    transform: translateX(4px);
  }

  .hint-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    opacity: 0.7;
    font-weight: 400;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
    width: 100%;
    padding: 0 0.5rem;
  }

  @media (min-width: 480px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      padding: 0;
    }
  }

  @media (min-width: 768px) {
    .features-grid {
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
  }

  /* Feature Card */
  .feature-card {
    position: relative;
    background: var(--bg-glass);
    border: 1px solid var(--border-primary);
    border-radius: 1rem;
    padding: 1.5rem;
    min-height: 160px;
    opacity: 0;
    transform: translateY(20px);
    animation: cardSlideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) var(--delay) forwards;
    cursor: pointer;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: hidden;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow:
      0 12px 24px -8px rgba(0, 0, 0, 0.4),
      0 0 0 1px var(--blue-primary),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 24px var(--blue-glow);
  }

  .feature-card:active {
    transform: translateY(-1px);
    transition: all 0.1s ease;
  }

  .feature-card:focus {
    outline: none;
    transform: translateY(-4px);
    box-shadow:
      0 12px 24px -8px rgba(0, 0, 0, 0.4),
      0 0 0 2px var(--accent-primary),
      0 0 24px var(--accent-glow);
  }

  .feature-icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    margin-bottom: 1rem;
    border-radius: 0.75rem;
    background: rgba(59, 130, 246, 0.1);
    color: var(--blue-secondary);
    transition: all 0.2s ease;
  }

  .feature-card:hover .feature-icon-wrapper {
    background: rgba(59, 130, 246, 0.15);
    color: var(--blue-primary);
  }

  .feature-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .feature-title {
      font-size: 1.0625rem;
    }
  }

  .feature-desc {
    font-size: 0.8125rem;
    margin: 0;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (min-width: 480px) {
    .feature-desc {
      font-size: 0.875rem;
    }
  }

  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cardSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes gradientShift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-container,
    .feature-card {
      animation: none !important;
    }

    .feature-card {
      opacity: 1;
      transform: none;
    }

    .glow-spot {
      opacity: 0.3;
    }
  }
</style>

<script is:inline define:vars={{ title }}>
  const container = document.querySelector('.hero-container');
  const cards = document.querySelectorAll('.feature-card');

  // 导航到产品介绍
  function navigateToProductOverview(event) {
    const target = event.target;

    // 排除主题切换按钮和其他不需要导航的元素
    const themeToggle = target.closest('[data-theme-toggle]') ||
                        target.closest('.sl-theme-toggle') ||
                        target.closest('.starlight-theme-toggle');
    if (themeToggle) {
      event.stopPropagation();
      event.preventDefault();
      return;
    }

    // 阻止事件冒泡，避免重复触发
    event.stopPropagation();
    event.preventDefault();

    // 添加导航反馈
    container.style.opacity = '0.7';
    container.style.transition = 'opacity 0.2s ease';

    // 延迟导航以显示反馈
    setTimeout(() => {
      window.location.href = '/product-overview';
    }, 150);
  }

  // 键盘导航
  function handleKeyDown(event) {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      navigateToProductOverview(event);
    }
  }

  // 容器交互
  container.addEventListener('click', navigateToProductOverview);
  container.addEventListener('keydown', handleKeyDown);
</script>
