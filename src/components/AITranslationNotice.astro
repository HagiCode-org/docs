---
type Props = {
  href: string;
  copy: {
    label: string;
    title: string;
    description: string;
    viewOriginal: string;
  };
};

const { href, copy } = Astro.props;
---

<aside class="ai-disclosure ai-disclosure--translation" aria-label={copy.title}>
  <p class="ai-disclosure__label">{copy.label}</p>
  <p class="ai-disclosure__title">{copy.title}</p>
  <p class="ai-disclosure__description">{copy.description}</p>
  <a class="ai-disclosure__link" href={href}>{copy.viewOriginal}</a>
</aside>
