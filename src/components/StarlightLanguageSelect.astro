---
import config from 'virtual:starlight/user-config';
import DocsLanguageSwitcher from './DocsLanguageSwitcher';
import { DOCS_LOCALE_RESOURCES, DOCS_LOCALE_SELECTOR_OPTIONS } from '../i18n/generated/docs-locale-resources.mjs';
import { DOCS_ROUTE_TO_SOURCE_LOCALE, parseDocsLocale, resolveDocsLocale } from '@/lib/i18n';

const localeFromPath = parseDocsLocale(Astro.url.pathname.split('/').filter(Boolean)[0] ?? null);
const currentLocale = resolveDocsLocale(
  Astro.currentLocale,
  Astro.locals?.starlightRoute?.locale,
  localeFromPath,
);
const sourceLocale = DOCS_ROUTE_TO_SOURCE_LOCALE[currentLocale];
const localeResources =
  DOCS_LOCALE_RESOURCES[sourceLocale] ?? DOCS_LOCALE_RESOURCES['en-US'];
const languageSelectCopy = localeResources.common.languageSelect;
const accessibleLabel = localeResources.starlight.languageSelect.accessibleLabel;
---

{
  config.isMultilingual && (
    <DocsLanguageSwitcher
      client:media="(min-width: 50rem)"
      currentLocale={currentLocale}
      currentPathname={Astro.url.pathname}
      options={DOCS_LOCALE_SELECTOR_OPTIONS}
      triggerAriaLabel={accessibleLabel}
      dialogTitle={languageSelectCopy.dialogTitle ?? accessibleLabel}
      currentLocaleLabel={languageSelectCopy.currentLocaleLabel}
      closeLabel={languageSelectCopy.closeLabel ?? accessibleLabel}
      selectedStateLabel={languageSelectCopy.selectedState ?? 'Selected'}
    />
  )
}
