---
import config from 'virtual:starlight/user-config';
import Select from '@astrojs/starlight/components/Select.astro';
import { DOCS_LOCALE_SELECTOR_OPTIONS } from '../i18n/generated/docs-locale-resources.mjs';
import { buildDocsCounterpartPath, normalizeDocsRoutePath, type DocsLocale } from '@/lib/i18n';

function buildLanguageSelectValue(locale: DocsLocale): string {
  return JSON.stringify({
    path: buildDocsCounterpartPath(locale, normalizeDocsRoutePath(Astro.url.pathname)),
    locale,
  });
}

const localeOptions = DOCS_LOCALE_SELECTOR_OPTIONS.filter(({ code }) => {
  if (!config.locales?.[code]) {
    return false;
  }

  return true;
});
---

{
  config.isMultilingual && (
    <starlight-lang-select>
      <Select
        icon="translate"
        label={Astro.locals.t('languageSelect.accessibleLabel')}
        options={localeOptions.map((locale) => ({
          value: buildLanguageSelectValue(locale.code),
          selected: locale.code === Astro.locals.starlightRoute.locale,
          label: locale.label,
        }))}
        width="7em"
      />
    </starlight-lang-select>
  )
}

<script>
  const DOCS_LANGUAGE_STORAGE_KEY = 'starlight-route';

  function parseSelectedLocaleTarget(value) {
    try {
      const parsed = JSON.parse(value);
      if (!parsed || typeof parsed !== 'object') {
        return null;
      }

      if (typeof parsed.path !== 'string' || typeof parsed.locale !== 'string') {
        return null;
      }

      return parsed;
    } catch (_error) {
      return null;
    }
  }

  function serializeStoredDocsLocale(storageValue, locale) {
    let routeObj = {};

    if (storageValue) {
      try {
        routeObj = JSON.parse(storageValue);
      } catch (_error) {
        routeObj = {};
      }
    }

    routeObj.lang = locale;
    return JSON.stringify(routeObj);
  }

  function persistSelectedDocsLocale(locale) {
    try {
      const previousValue = localStorage.getItem(DOCS_LANGUAGE_STORAGE_KEY);
      localStorage.setItem(
        DOCS_LANGUAGE_STORAGE_KEY,
        serializeStoredDocsLocale(previousValue, locale),
      );
    } catch (_error) {
      // Ignore storage failures and still attempt navigation.
    }
  }

  class StarlightLanguageSelect extends HTMLElement {
    constructor() {
      super();
      const select = this.querySelector('select');
      if (select) {
        select.addEventListener('change', (e) => {
          if (e.currentTarget instanceof HTMLSelectElement) {
            const target = parseSelectedLocaleTarget(e.currentTarget.value);
            if (!target) {
              return;
            }

             persistSelectedDocsLocale(target.locale);
            const currentUrl = new URL(window.location.href);
            const nextUrl = new URL(target.path, currentUrl.origin);
            nextUrl.search = currentUrl.search;
            nextUrl.hash = currentUrl.hash;
            window.location.href = nextUrl.toString();
          }
        });
        window.addEventListener('pageshow', (event) => {
          if (!event.persisted) return;
          const markupSelectedIndex =
            select.querySelector('option[selected]')?.index;
          if (markupSelectedIndex !== select.selectedIndex) {
            select.selectedIndex = markupSelectedIndex ?? 0;
          }
        });
      }
    }
  }

  customElements.define('starlight-lang-select', StarlightLanguageSelect);
</script>
