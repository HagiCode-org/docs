---
/**
 * 博客文章末尾固定的转化回收 CTA。
 *
 * 解决问题：blog 流量进入文档站后没有统一的回收口，用户读完即流失。
 * 此组件在每篇博客正文（含相关链接区）之后固定渲染，提供两条出口：
 *   1. Microsoft Store 安装（外链，直接转化）
 *   2. 版本与定价页（站内，回收至 product-overview 的定价区）
 *
 * 设计原则：
 * - 纯服务端渲染，无 JS 依赖，不依赖外部 promotion 数据源。
 * - 与 BlogFooterAd 解耦：即便相关链接为空或被 hideAd 关闭，此 CTA 仍然固定存在。
 * - 文案走 zh / en 两套，其余 locale 回退到 en。
 */
import { resolveDocsLocale, type DocsLocale } from '@/lib/i18n';
import { localizeDocsHref } from '@/lib/articles.mjs';
import { DEFAULT_WINDOWS_STORE_PRODUCT_ID } from '@/lib/microsoft-store-badge';

interface Props {
  /** 当前语言（Starlight locale），缺省时从 Astro.currentLocale 解析 */
  locale?: string;
}

const { locale } = Astro.props;
const currentLocale: DocsLocale = resolveDocsLocale(Astro.currentLocale, locale, Astro.locals?.starlightRoute?.locale);

const MICROSOFT_STORE_HREF = `https://apps.microsoft.com/detail/${DEFAULT_WINDOWS_STORE_PRODUCT_ID}`;

const copy = currentLocale === 'en'
  ? {
      kicker: 'Get HagiCode',
      title: 'Install once, start in minutes',
      description:
        'HagiCode for Windows is free on the Microsoft Store. Open the store to install and stay up to date, or compare editions and pricing before you decide.',
      storeLabel: 'Get it from Microsoft Store',
      pricingLabel: 'Compare editions & pricing',
      storeAria: 'Open HagiCode on Microsoft Store',
    }
  : {
      kicker: '开始使用 HagiCode',
      title: '一次安装，几分钟上手',
      description:
        'HagiCode for Windows 在 Microsoft Store 免费提供。打开商店即可安装并保持更新；也可以先对比各版本与定价，再决定从哪个渠道开始。',
      storeLabel: '前往 Microsoft Store 安装',
      pricingLabel: '查看版本与定价',
      storeAria: '在 Microsoft Store 打开 HagiCode',
    };

// 定价锚点随 locale 翻译变化，统一指向 product-overview 页（定价表格位于页面内）。
const pricingHref = localizeDocsHref('/product-overview/', currentLocale);
---

<section class="blog-cta" data-pagefind-ignore aria-labelledby="blog-cta-title">
  <div class="blog-cta__inner">
    <p class="blog-cta__kicker">{copy.kicker}</p>
    <h2 id="blog-cta-title" class="blog-cta__title">{copy.title}</h2>
    <p class="blog-cta__desc">{copy.description}</p>
    <div class="blog-cta__actions">
      <a
        class="blog-cta__btn blog-cta__btn--primary"
        href={MICROSOFT_STORE_HREF}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={copy.storeAria}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
        {copy.storeLabel}
      </a>
      <a class="blog-cta__btn blog-cta__btn--secondary" href={pricingHref}>
        {copy.pricingLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .blog-cta {
    --cta-text-high: #111827;
    --cta-text-normal: #334155;
    margin-block-start: 2rem;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border-radius: var(--sl-radius-md);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 24%, var(--sl-color-gray-5));
    background:
      radial-gradient(
        120% 140% at 0% 0%,
        color-mix(in srgb, var(--sl-color-accent) 12%, transparent) 0%,
        transparent 55%
      ),
      color-mix(in srgb, var(--sl-color-bg-nav) 92%, var(--sl-color-bg));
  }

  :global([data-theme='dark']) .blog-cta {
    --cta-text-high: #f8fafc;
    --cta-text-normal: #cbd5e1;
  }

  .blog-cta__inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-cta__kicker {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-accent-high);
  }

  .blog-cta__title {
    margin: 0;
    font-size: clamp(1.15rem, 2.4vw, 1.4rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--cta-text-high);
  }

  .blog-cta__desc {
    margin: 0;
    max-width: 60ch;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--cta-text-normal);
  }

  .blog-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-start: 0.75rem;
  }

  .blog-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 2.75rem;
    padding: 0.625rem 1.1rem;
    border-radius: var(--sl-radius-sm);
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.2;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease;
  }

  .blog-cta__btn:hover {
    transform: translateY(-1px);
  }

  .blog-cta__btn--primary {
    background: var(--sl-color-accent, #0080ff);
    color: #f8fbff;
    box-shadow: 0 12px 28px rgb(37 99 235 / 0.16);
    -webkit-text-fill-color: #f8fbff !important;
  }

  .blog-cta__btn--primary:hover {
    background: var(--sl-color-accent-high, #245ea8);
  }

  .blog-cta__btn--secondary {
    border-color: var(--sl-color-gray-5);
    color: var(--sl-color-text);
    background: color-mix(in srgb, var(--sl-color-bg) 95%, var(--sl-color-bg-nav) 5%);
  }

  .blog-cta__btn--secondary:hover {
    border-color: color-mix(in srgb, var(--sl-color-accent) 30%, var(--sl-color-gray-5));
    color: var(--sl-color-accent-high);
  }

  @media (max-width: 640px) {
    .blog-cta__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .blog-cta__btn {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-cta__btn,
    .blog-cta__btn:hover {
      transition: none;
      transform: none;
    }
  }

  @media (forced-colors: active) {
    .blog-cta,
    .blog-cta__btn {
      color: CanvasText;
      border-color: CanvasText;
    }
  }
</style>
