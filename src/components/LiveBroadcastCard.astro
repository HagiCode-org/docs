---
import LiveBroadcastCardClient from './LiveBroadcastCardClient';
import { getBundledLiveBroadcastData, type LiveBroadcastLocale } from '@/lib/live-broadcast';

interface Props {
  locale: LiveBroadcastLocale;
}

const { locale } = Astro.props;
const initialData = getBundledLiveBroadcastData();
---

<LiveBroadcastCardClient client:load locale={locale} initialData={initialData} />
