---
import LiveBroadcastCardClient from './LiveBroadcastCardClient';
import { FEATURE_LIVE_BROADCAST_ENABLED } from '@/config/features';
import { getBundledLiveBroadcastData, type LiveBroadcastLocale } from '@/lib/live-broadcast';

interface Props {
  locale: LiveBroadcastLocale;
}

const { locale } = Astro.props;
const initialData = FEATURE_LIVE_BROADCAST_ENABLED ? getBundledLiveBroadcastData() : null;
---

{FEATURE_LIVE_BROADCAST_ENABLED && (
  <LiveBroadcastCardClient
    client:load
    locale={locale}
    enabled={FEATURE_LIVE_BROADCAST_ENABLED}
    initialData={initialData}
  />
)}
