---
import { resolveDocsLocale, type DocsLocale } from '@/lib/i18n';

interface Props {
  locale?: string;
}

const { locale } = Astro.props;
const currentLocale: DocsLocale = resolveDocsLocale(
  Astro.currentLocale,
  locale,
  Astro.locals?.starlightRoute?.locale,
);

const localizedText = currentLocale === 'en'
  ? {
      bannerLabel: 'Featured docs entry',
      closeLabel: 'Dismiss promotion message',
      previousLabel: 'Show previous promotion',
      nextLabel: 'Show next promotion',
      pauseLabel: 'Pause automatic rotation',
      resumeLabel: 'Resume automatic rotation',
      countLabel: 'Promotion progress',
      statusLabel: 'Current promotion',
    }
  : {
      bannerLabel: '文档推荐入口',
      closeLabel: '关闭推广信息',
      previousLabel: '查看上一条推广',
      nextLabel: '查看下一条推广',
      pauseLabel: '暂停自动轮播',
      resumeLabel: '恢复自动轮播',
      countLabel: '推广进度',
      statusLabel: '当前推广',
    };
---

<docs-promote-banner class="docs-promote-banner-host" data-locale={currentLocale} hidden>
  <div class="docs-promote-banner__spacer" data-promote-banner-spacer aria-hidden="true"></div>

  <section
    class="docs-promote-banner__shell"
    data-promote-banner-shell
    hidden
    aria-label={localizedText.bannerLabel}
  >
    <div class="docs-promote-banner__inner">
      <button
        type="button"
        class="docs-promote-banner__close"
        data-promote-banner-close
        aria-label={localizedText.closeLabel}
      >
        <span aria-hidden="true">×</span>
      </button>

      <div class="docs-promote-banner__body">
        <div class="docs-promote-banner__viewport">
          <div class="docs-promote-banner__track" data-promote-banner-track></div>
        </div>

        <div class="docs-promote-banner__controls" data-promote-banner-controls hidden>
          <button
            type="button"
            class="docs-promote-banner__control"
            data-promote-banner-previous
            aria-label={localizedText.previousLabel}
          >
            <span aria-hidden="true">‹</span>
          </button>

          <span
            class="docs-promote-banner__count"
            data-promote-banner-count
            aria-label={localizedText.countLabel}
          ></span>

          <button
            type="button"
            class="docs-promote-banner__control"
            data-promote-banner-next
            aria-label={localizedText.nextLabel}
          >
            <span aria-hidden="true">›</span>
          </button>

          <button
            type="button"
            class="docs-promote-banner__control docs-promote-banner__pause"
            data-promote-banner-pause
            data-rotation-pause-label={localizedText.pauseLabel}
            data-rotation-resume-label={localizedText.resumeLabel}
            aria-label={localizedText.pauseLabel}
          >
            {currentLocale === 'en' ? 'Pause' : '暂停'}
          </button>
        </div>
      </div>
    </div>

    <span class="docs-promote-banner__status sr-only" data-promote-banner-status aria-live="polite">
      {localizedText.statusLabel}
    </span>
  </section>
</docs-promote-banner>

<script>
  import { defineDocsPromoteBannerElement } from '@/lib/docs-promote-banner';

  defineDocsPromoteBannerElement();
</script>

<style is:global>
  .docs-promote-banner-host .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .docs-promote-banner-host {
    display: block;
  }

  .docs-promote-banner-host[hidden] {
    display: none !important;
  }

  .docs-promote-banner__spacer {
    width: 100%;
    height: 0;
    transition: height 0.24s ease;
  }

  .docs-promote-banner__shell {
    --docs-promote-banner-base-bottom: max(1rem, env(safe-area-inset-bottom));
    --docs-promote-banner-border: color-mix(in srgb, var(--sl-color-accent) 24%, var(--sl-color-gray-5));
    --docs-promote-banner-surface:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-accent) 14%, var(--sl-color-bg) 86%),
        color-mix(in srgb, var(--sl-color-accent-high) 8%, var(--sl-color-bg-sidebar) 92%)
      );
    --docs-promote-banner-shadow: 0 24px 80px color-mix(in srgb, var(--sl-color-black) 22%, transparent);
    --docs-promote-banner-close-border: color-mix(in srgb, var(--sl-color-accent-high) 20%, var(--sl-color-gray-5));
    --docs-promote-banner-close-bg: color-mix(in srgb, var(--sl-color-bg) 74%, transparent);
    --docs-promote-banner-close-hover-bg: color-mix(in srgb, var(--sl-color-bg-nav) 84%, transparent);
    --docs-promote-banner-close-color: var(--sl-color-white);
    --docs-promote-banner-badge-border: color-mix(in srgb, var(--sl-color-accent) 34%, transparent);
    --docs-promote-banner-badge-bg: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    --docs-promote-banner-badge-color: color-mix(in srgb, var(--sl-color-accent-high) 72%, var(--sl-color-white) 28%);
    --docs-promote-banner-description-color: color-mix(in srgb, var(--sl-color-white) 72%, var(--sl-color-gray-3));
    --docs-promote-banner-control-border: color-mix(in srgb, var(--sl-color-accent-high) 18%, var(--sl-color-gray-5));
    --docs-promote-banner-control-bg: color-mix(in srgb, var(--sl-color-bg) 76%, transparent);
    --docs-promote-banner-control-hover-bg: color-mix(in srgb, var(--sl-color-bg-nav) 84%, transparent);
    --docs-promote-banner-control-color: var(--sl-color-white);
    --docs-promote-banner-count-color: color-mix(in srgb, var(--sl-color-white) 70%, var(--sl-color-gray-3));
    position: fixed;
    inset-inline: 0;
    bottom: var(--docs-promote-banner-base-bottom);
    z-index: 40;
    pointer-events: none;
    opacity: 1;
    visibility: visible;
    transition:
      opacity 0.24s ease,
      visibility 0s linear 0s;
  }

  [data-theme='light'] .docs-promote-banner__shell {
    --docs-promote-banner-border: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-5));
    --docs-promote-banner-surface:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-accent) 10%, white 90%),
        color-mix(in srgb, var(--sl-color-accent-high) 6%, var(--sl-color-bg-sidebar) 94%)
      );
    --docs-promote-banner-shadow: 0 18px 54px rgba(15, 23, 42, 0.12);
    --docs-promote-banner-close-bg: color-mix(in srgb, white 78%, var(--sl-color-bg) 22%);
    --docs-promote-banner-close-hover-bg: color-mix(in srgb, white 66%, var(--sl-color-bg-nav) 34%);
    --docs-promote-banner-badge-bg: color-mix(in srgb, var(--sl-color-accent) 8%, white 92%);
    --docs-promote-banner-description-color: color-mix(in srgb, var(--sl-color-white) 74%, var(--sl-color-gray-3));
    --docs-promote-banner-control-bg: color-mix(in srgb, white 78%, var(--sl-color-bg) 22%);
    --docs-promote-banner-control-hover-bg: color-mix(in srgb, white 64%, var(--sl-color-bg-nav) 36%);
  }

  [data-theme='dark'] .docs-promote-banner__shell {
    --docs-promote-banner-surface:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--sl-color-accent) 16%, rgba(10, 10, 10, 0.72)),
        color-mix(in srgb, var(--sl-color-accent-high) 10%, rgba(10, 10, 10, 0.82))
      );
    --docs-promote-banner-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
    --docs-promote-banner-close-bg: rgba(10, 10, 10, 0.36);
    --docs-promote-banner-close-hover-bg: rgba(10, 10, 10, 0.5);
    --docs-promote-banner-badge-bg: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    --docs-promote-banner-control-bg: rgba(255, 255, 255, 0.05);
    --docs-promote-banner-control-hover-bg: rgba(255, 255, 255, 0.08);
  }

  .docs-promote-banner__shell[hidden] {
    display: none !important;
  }

  .docs-promote-banner__inner {
    position: relative;
    pointer-events: auto;
    width: min(72rem, calc(100vw - 1rem));
    margin-inline: auto;
    overflow: hidden;
    border: 1px solid var(--docs-promote-banner-border);
    border-radius: 28px;
    background: var(--docs-promote-banner-surface);
    box-shadow: var(--docs-promote-banner-shadow);
    backdrop-filter: blur(18px);
    transition:
      opacity 0.24s ease,
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .docs-promote-banner-host:not([data-state='footer-hidden']) .docs-promote-banner__inner:hover,
  .docs-promote-banner-host:not([data-state='footer-hidden']) .docs-promote-banner__inner:focus-within {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 32%, var(--docs-promote-banner-border));
    box-shadow: 0 28px 86px color-mix(in srgb, var(--sl-color-black) 26%, transparent);
  }

  .docs-promote-banner-host[data-state='footer-hidden'] .docs-promote-banner__shell {
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.24s ease,
      visibility 0s linear 0.24s;
  }

  .docs-promote-banner-host[data-state='footer-hidden'] .docs-promote-banner__inner {
    pointer-events: none;
    opacity: 0;
    transform: translateY(0.5rem);
  }

  .docs-promote-banner__close {
    position: absolute;
    inset-block-start: 0.85rem;
    inset-inline-end: 0.85rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid var(--docs-promote-banner-close-border);
    border-radius: 999px;
    background: var(--docs-promote-banner-close-bg);
    color: var(--docs-promote-banner-close-color);
    cursor: pointer;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease;
  }

  .docs-promote-banner__close:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 34%, var(--docs-promote-banner-close-border));
    background: var(--docs-promote-banner-close-hover-bg);
  }

  .docs-promote-banner__close:focus-visible,
  .docs-promote-banner__slide:focus-visible,
  .docs-promote-banner__control:focus-visible {
    outline: 3px solid rgba(125, 255, 224, 0.9);
    outline-offset: 4px;
  }

  .docs-promote-banner__body {
    display: grid;
    gap: 0.75rem;
  }

  .docs-promote-banner__viewport {
    position: relative;
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .docs-promote-banner__track {
    display: flex;
    align-items: stretch;
    width: 100%;
    transition: transform 0.34s ease;
    will-change: transform;
  }

  .docs-promote-banner__slide {
    appearance: none;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    min-width: 100%;
    border: 0;
    border-radius: inherit;
    background: transparent;
    color: inherit;
    cursor: pointer;
    padding: 1.25rem 4rem 1.25rem 1.25rem;
    text-align: left;
  }

  .docs-promote-banner__slide[data-has-image='true'] {
    grid-template-columns: minmax(0, 1fr) auto auto;
  }

  .docs-promote-banner__copy {
    min-width: 0;
    display: grid;
    grid-template-columns: auto minmax(13rem, 0.75fr) minmax(18rem, 1.15fr);
    align-items: center;
    gap: 1rem;
  }

  .docs-promote-banner__badge {
    margin: 0;
    border-radius: 999px;
    border: 1px solid var(--docs-promote-banner-badge-border);
    background: var(--docs-promote-banner-badge-bg);
    color: var(--docs-promote-banner-badge-color);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 0.45rem 0.8rem;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .docs-promote-banner__title {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.34;
  }

  .docs-promote-banner__description {
    margin: 0;
    color: var(--docs-promote-banner-description-color);
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.34;
  }

  .docs-promote-banner__media {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(4.5rem, 8vw, 6.25rem);
    min-width: clamp(4.5rem, 8vw, 6.25rem);
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent-high) 18%, var(--sl-color-gray-5));
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg-sidebar) 82%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sl-color-white) 5%, transparent);
  }

  .docs-promote-banner__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .docs-promote-banner__actions {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 7.5rem;
  }

  .docs-promote-banner__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    min-width: 7.5rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #25c2a0, #06b6d4);
    color: #04110f;
    font-size: 0.875rem;
    font-weight: 800;
    padding: 0 1rem;
    white-space: nowrap;
    transition: transform 0.18s ease;
  }

  .docs-promote-banner__slide:hover .docs-promote-banner__cta,
  .docs-promote-banner__slide:focus-visible .docs-promote-banner__cta {
    transform: translateX(2px);
  }

  .docs-promote-banner__controls {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 0 1.25rem 1.1rem;
  }

  .docs-promote-banner__control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    min-width: 2.5rem;
    padding: 0 0.8rem;
    border: 1px solid var(--docs-promote-banner-control-border);
    border-radius: 999px;
    background: var(--docs-promote-banner-control-bg);
    color: var(--docs-promote-banner-control-color);
    cursor: pointer;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease;
  }

  .docs-promote-banner__control:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 34%, var(--docs-promote-banner-control-border));
    background: var(--docs-promote-banner-control-hover-bg);
  }

  .docs-promote-banner__pause {
    min-width: 4.75rem;
    font-size: 0.8125rem;
  }

  .docs-promote-banner__count {
    min-width: 3.5rem;
    text-align: center;
    color: var(--docs-promote-banner-count-color);
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .docs-promote-banner__controls[hidden],
  .docs-promote-banner__control[hidden],
  .docs-promote-banner__count[hidden] {
    display: none !important;
  }

  .docs-promote-banner__control:disabled {
    opacity: 0.6;
    cursor: default;
    transform: none;
  }

  @media (max-width: 960px) {
    .docs-promote-banner__inner {
      width: min(100vw - 1rem, 44rem);
      border-radius: 1.15rem;
    }

    .docs-promote-banner__slide {
      grid-template-columns: 1fr;
      padding-inline-end: 3.7rem;
    }

    .docs-promote-banner__slide[data-has-image='true'] {
      grid-template-columns: 1fr;
    }

    .docs-promote-banner__copy {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .docs-promote-banner__media {
      width: min(100%, 8rem);
      min-width: 0;
    }

    .docs-promote-banner__actions {
      justify-content: flex-start;
    }

    .docs-promote-banner__controls {
      justify-content: flex-start;
      padding-top: 0;
    }
  }

  @media (max-width: 720px) {
    .docs-promote-banner__shell {
      --docs-promote-banner-base-bottom: calc(env(safe-area-inset-bottom) + 0.5rem);
    }

    .docs-promote-banner__inner {
      width: min(calc(100vw - 1rem), 24rem);
      border-radius: 1rem;
    }

    .docs-promote-banner__slide {
      grid-template-columns: 1fr;
      gap: 0.7rem;
      padding: 0.85rem 4.8rem 0.85rem 0.85rem;
    }

    .docs-promote-banner__slide[data-has-image='true'] {
      grid-template-columns: minmax(0, 1fr) 4.5rem;
      align-items: start;
    }

    .docs-promote-banner__badge {
      max-width: max-content;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      padding: 0.35rem 0.65rem;
    }

    .docs-promote-banner__copy {
      gap: 0.45rem;
    }

    .docs-promote-banner__title {
      font-size: 0.92rem;
    }

    .docs-promote-banner__description {
      display: -webkit-box;
      overflow: hidden;
      font-size: 0.84rem;
      font-weight: 500;
      line-height: 1.3;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .docs-promote-banner__media {
      width: 4.5rem;
      min-width: 4.5rem;
      align-self: start;
      border-radius: 0.8rem;
    }

    .docs-promote-banner__actions {
      grid-column: 1 / -1;
      justify-content: stretch;
      min-width: 0;
    }

    .docs-promote-banner__cta {
      min-height: 2.35rem;
      min-width: 0;
      width: 100%;
      font-size: 0.82rem;
      white-space: normal;
    }

    .docs-promote-banner__controls {
      flex-wrap: wrap;
      gap: 0.35rem;
      padding: 0 0.85rem 0.9rem;
    }

    .docs-promote-banner__control {
      min-height: 2.2rem;
      min-width: 2.2rem;
    }

    .docs-promote-banner__pause {
      min-width: 4.4rem;
    }

    .docs-promote-banner__count {
      min-width: 2.75rem;
      font-size: 0.75rem;
    }

    .docs-promote-banner__close {
      inset-block-start: 0.55rem;
      inset-inline-end: 0.55rem;
      width: auto;
      min-width: 2rem;
      height: 2rem;
      gap: 0.25rem;
      padding-inline: 0.55rem;
      background: color-mix(in srgb, var(--docs-promote-banner-close-bg) 82%, var(--sl-color-black) 18%);
    }

  }

  @media (prefers-reduced-motion: reduce) {
    .docs-promote-banner__spacer,
    .docs-promote-banner__shell,
    .docs-promote-banner__inner,
    .docs-promote-banner__track,
    .docs-promote-banner__cta,
    .docs-promote-banner__control,
    .docs-promote-banner__close {
      transition: none;
    }
  }
</style>
