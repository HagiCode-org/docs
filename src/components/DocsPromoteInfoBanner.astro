---
import { resolveDocsLocale, type DocsLocale } from '@/lib/i18n';

interface Props {
  locale?: string;
}

const { locale } = Astro.props;
const currentLocale: DocsLocale = resolveDocsLocale(
  Astro.currentLocale,
  locale,
  Astro.locals?.starlightRoute?.locale,
);

const localizedText = currentLocale === 'en'
  ? {
      bannerLabel: 'Promoted links',
      closeLabel: 'Dismiss promotion message',
      previousLabel: 'Show previous promotion',
      nextLabel: 'Show next promotion',
      pauseLabel: 'Pause automatic rotation',
      countLabel: 'Promotion progress',
      statusLabel: 'Current promotion',
    }
  : {
      bannerLabel: '推广信息',
      closeLabel: '关闭推广信息',
      previousLabel: '查看上一条推广',
      nextLabel: '查看下一条推广',
      pauseLabel: '暂停自动轮播',
      countLabel: '推广进度',
      statusLabel: '当前推广',
    };
---

<docs-promote-banner class="docs-promote-banner-host" data-locale={currentLocale} hidden>
  <div class="docs-promote-banner__spacer" data-promote-banner-spacer aria-hidden="true"></div>

  <section
    class="docs-promote-banner__shell"
    data-promote-banner-shell
    hidden
    aria-label={localizedText.bannerLabel}
  >
    <div class="docs-promote-banner__inner">
      <button
        type="button"
        class="docs-promote-banner__close"
        data-promote-banner-close
        aria-label={localizedText.closeLabel}
      >
        <span aria-hidden="true">×</span>
      </button>

      <div class="docs-promote-banner__viewport">
        <div class="docs-promote-banner__track" data-promote-banner-track></div>
      </div>

      <div class="docs-promote-banner__controls">
        <button
          type="button"
          class="docs-promote-banner__control"
          data-promote-banner-previous
          aria-label={localizedText.previousLabel}
        >
          <span aria-hidden="true">‹</span>
        </button>

        <span
          class="docs-promote-banner__count"
          data-promote-banner-count
          aria-label={localizedText.countLabel}
        ></span>

        <button
          type="button"
          class="docs-promote-banner__control"
          data-promote-banner-next
          aria-label={localizedText.nextLabel}
        >
          <span aria-hidden="true">›</span>
        </button>

        <button
          type="button"
          class="docs-promote-banner__control docs-promote-banner__pause"
          data-promote-banner-pause
          aria-label={localizedText.pauseLabel}
        >
          {currentLocale === 'en' ? 'Pause' : '暂停'}
        </button>
      </div>
    </div>

    <span class="docs-promote-banner__status sr-only" data-promote-banner-status aria-live="polite">
      {localizedText.statusLabel}
    </span>
  </section>
</docs-promote-banner>

<script>
  import { defineDocsPromoteBannerElement } from '@/lib/docs-promote-banner';

  defineDocsPromoteBannerElement();
</script>

<style is:global>
  .docs-promote-banner-host .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .docs-promote-banner-host {
    display: block;
  }

  .docs-promote-banner-host[hidden] {
    display: none !important;
  }

  .docs-promote-banner__spacer {
    width: 100%;
    height: 0;
    transition: height 0.24s ease;
  }

  .docs-promote-banner__shell {
    --docs-promote-banner-bottom-offset: 0px;
    position: fixed;
    inset-inline: 0;
    bottom: calc(1rem + var(--docs-promote-banner-bottom-offset));
    z-index: 40;
    pointer-events: none;
  }

  .docs-promote-banner__inner {
    position: relative;
    pointer-events: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.875rem;
    width: min(72rem, calc(100vw - 1rem));
    margin: 0 auto;
    padding: 1.1rem 3.8rem 0.95rem 1rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-5));
    border-radius: 1.1rem;
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--sl-color-accent) 12%, var(--sl-color-bg)) 0%, var(--sl-color-black) 100%);
    box-shadow:
      0 20px 45px rgba(15, 23, 42, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    backdrop-filter: blur(14px);
    isolation: isolate;
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      background-position 0.3s ease;
  }

  .docs-promote-banner__shell[hidden] {
    display: none !important;
  }

  .docs-promote-banner__inner::before,
  .docs-promote-banner__inner::after {
    content: '';
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .docs-promote-banner__inner::before {
    inset-block-start: -8rem;
    inset-inline-start: -4rem;
    width: 20rem;
    height: 20rem;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--sl-color-accent-high) 55%, white 12%) 0%,
      transparent 68%
    );
    opacity: 0.24;
    filter: blur(12px);
    animation: docs-promote-banner-glow 11s ease-in-out infinite alternate;
  }

  .docs-promote-banner__inner::after {
    inset: -24% auto -24% 42%;
    width: 42%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255, 255, 255, 0.03) 18%,
      rgba(255, 255, 255, 0.16) 34%,
      transparent 58%
    );
    transform: translate3d(-140%, 0, 0) rotate(10deg);
    opacity: 0.42;
    animation: docs-promote-banner-sheen 9s linear infinite;
  }

  .docs-promote-banner__inner:hover,
  .docs-promote-banner__inner:focus-within {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 34%, var(--sl-color-white) 10%);
    box-shadow:
      0 26px 48px rgba(15, 23, 42, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
  }

  .docs-promote-banner__viewport {
    position: relative;
    z-index: 1;
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .docs-promote-banner__close {
    position: absolute;
    inset-block-start: 0.7rem;
    inset-inline-end: 0.75rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-white) 16%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-white) 7%, transparent);
    color: color-mix(in srgb, var(--sl-color-white) 90%, var(--sl-color-gray-2));
    cursor: pointer;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .docs-promote-banner__close:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 34%, var(--sl-color-white) 12%);
    background: color-mix(in srgb, var(--sl-color-white) 11%, transparent);
  }

  .docs-promote-banner__close:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--sl-color-accent-high) 72%, white 28%);
    outline-offset: 2px;
  }

  .docs-promote-banner__track {
    display: flex;
    align-items: stretch;
    width: 100%;
    transition: transform 0.34s ease;
    will-change: transform;
  }

  .docs-promote-banner__slide {
    appearance: none;
    flex: 0 0 100%;
    inline-size: 100%;
    max-inline-size: 100%;
    text-align: left;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    width: 100%;
    min-width: 100%;
    position: relative;
    padding: 1rem 1.05rem;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    transition: none;
    cursor: pointer;
  }

  .docs-promote-banner__slide:focus-visible {
    outline: none;
  }

  .docs-promote-banner__copy {
    min-width: 0;
    width: 100%;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(0, 1.15fr);
    align-items: center;
    column-gap: 1rem;
    row-gap: 0.22rem;
    position: relative;
    z-index: 1;
  }

  .docs-promote-banner__platform {
    margin: 0;
    align-self: center;
    padding: 0.38rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-white) 14%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-white) 7%, transparent);
    color: color-mix(in srgb, var(--sl-color-white) 78%, var(--sl-color-gray-3));
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .docs-promote-banner__title {
    margin: 0;
    color: var(--sl-color-white);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.34;
    letter-spacing: 0.01em;
  }

  .docs-promote-banner__description {
    margin: 0;
    color: color-mix(in srgb, var(--sl-color-white) 92%, var(--sl-color-accent-high) 8%);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.34;
    letter-spacing: 0.01em;
  }

  .docs-promote-banner__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 7.5rem;
    position: relative;
    z-index: 1;
  }

  .docs-promote-banner__cta,
  .docs-promote-banner__control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    border-radius: 999px;
    text-decoration: none;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .docs-promote-banner__cta {
    padding: 0 1rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-white) 14%, transparent);
    background: linear-gradient(135deg, var(--sl-color-accent), color-mix(in srgb, var(--sl-color-accent-high) 82%, white 18%));
    color: var(--sl-color-black);
    font-size: 0.875rem;
    font-weight: 700;
    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.16);
  }

  .docs-promote-banner__cta:hover,
  .docs-promote-banner__control:hover {
    transform: translateY(-1px);
  }

  .docs-promote-banner__inner:hover .docs-promote-banner__cta,
  .docs-promote-banner__inner:focus-within .docs-promote-banner__cta {
    transform: translateX(2px);
  }

  .docs-promote-banner__controls {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    justify-self: end;
    position: relative;
    z-index: 1;
  }

  .docs-promote-banner__control {
    min-width: 2.6rem;
    padding: 0 0.8rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-white) 14%, transparent);
    background: color-mix(in srgb, var(--sl-color-white) 6%, transparent);
    color: var(--sl-color-white);
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
  }

  .docs-promote-banner__pause {
    min-width: 4.5rem;
    font-size: 0.8125rem;
  }

  .docs-promote-banner__count {
    min-width: 3.5rem;
    text-align: center;
    color: color-mix(in srgb, var(--sl-color-white) 76%, var(--sl-color-gray-3));
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .docs-promote-banner__cta:focus-visible,
  .docs-promote-banner__control:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--sl-color-accent-high) 72%, white 28%);
    outline-offset: 2px;
  }

  .docs-promote-banner__control[hidden],
  .docs-promote-banner__count[hidden] {
    display: none !important;
  }

  .docs-promote-banner__control:disabled {
    opacity: 0.6;
    cursor: default;
    transform: none;
  }

  @media (max-width: 960px) {
    .docs-promote-banner__shell {
      width: 100%;
    }

    .docs-promote-banner__inner {
      width: min(100vw - 1rem, 44rem);
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding-inline-end: 3.6rem;
    }

    .docs-promote-banner__controls {
      width: 100%;
      justify-content: flex-end;
    }

    .docs-promote-banner__slide {
      grid-template-columns: 1fr;
    }

    .docs-promote-banner__copy {
      grid-template-columns: 1fr;
      align-items: start;
      row-gap: 0.3rem;
    }

    .docs-promote-banner__actions {
      justify-content: flex-start;
      min-width: 0;
    }
  }

  @media (max-width: 640px) {
    .docs-promote-banner__shell {
      bottom: calc(0.5rem + var(--docs-promote-banner-bottom-offset));
      width: 100%;
    }

    .docs-promote-banner__inner {
      width: calc(100vw - 0.75rem);
      padding: 1rem 3.45rem 0.85rem 0.85rem;
      border-radius: 1rem;
    }

    .docs-promote-banner__title {
      font-size: 0.92rem;
    }

    .docs-promote-banner__description {
      font-size: 0.92rem;
    }

    .docs-promote-banner__controls {
      justify-content: space-between;
      gap: 0.4rem;
    }

    .docs-promote-banner__count {
      min-width: 3rem;
    }

    .docs-promote-banner__cta,
    .docs-promote-banner__control {
      min-height: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .docs-promote-banner__spacer,
    .docs-promote-banner__track,
    .docs-promote-banner__cta,
    .docs-promote-banner__control,
    .docs-promote-banner__close,
    .docs-promote-banner__slide {
      transition: none;
    }

    .docs-promote-banner__slide::before,
    .docs-promote-banner__slide::after,
    .docs-promote-banner__inner::before,
    .docs-promote-banner__inner::after {
      animation: none;
    }
  }

  @keyframes docs-promote-banner-glow {
    0% {
      transform: translate3d(-0.75rem, -0.45rem, 0) scale(0.92);
      opacity: 0.24;
    }

    100% {
      transform: translate3d(1.25rem, 0.95rem, 0) scale(1.14);
      opacity: 0.42;
    }
  }

  @keyframes docs-promote-banner-sheen {
    0% {
      transform: translate3d(-120%, 0, 0) rotate(10deg);
    }

    100% {
      transform: translate3d(150%, 0, 0) rotate(10deg);
    }
  }
</style>
