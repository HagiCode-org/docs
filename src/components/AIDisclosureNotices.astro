---
import AIAuthorNotice from './AIAuthorNotice.astro';
import AITranslationNotice from './AITranslationNotice.astro';
import { buildAIDisclosureNotices } from '@/lib/ai-disclosures';
import { getDocsAIDisclosureCopy } from '@/lib/i18n';

type Props = {
  isAITranslation: boolean;
  isAIAuthor: boolean;
  locale: string | null | undefined;
  pathname: string;
};

const { isAITranslation, isAIAuthor, locale, pathname } = Astro.props;
const notices = buildAIDisclosureNotices({
  isAITranslation,
  isAIAuthor,
  locale,
  pathname,
});
const copy = getDocsAIDisclosureCopy(locale);
---

{
  notices.length > 0 && (
    <div class="ai-disclosure-stack" data-ai-disclosures>
      {notices.map((notice) =>
        notice.kind === 'translation'
          ? <AITranslationNotice href={notice.sourceHref} copy={copy.translation} />
          : <AIAuthorNotice copy={copy.author} />
      )}
    </div>
  )
}

<style is:global>
  .ai-disclosure-stack {
    display: grid;
    gap: 0.85rem;
    margin: 0 0 1.25rem;
  }

  .ai-disclosure {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg-sidebar) 90%, var(--sl-color-accent-low) 10%);
  }

  .ai-disclosure__label,
  .ai-disclosure__title,
  .ai-disclosure__description {
    margin: 0;
  }

  .ai-disclosure__label {
    color: var(--sl-color-accent-high);
    font-size: var(--sl-text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ai-disclosure__title {
    color: var(--sl-color-text-high);
    font-size: var(--sl-text-base);
    font-weight: 700;
  }

  .ai-disclosure__description {
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    line-height: 1.6;
  }

  .ai-disclosure__link {
    justify-self: start;
    color: var(--sl-color-text-accent);
    font-size: var(--sl-text-sm);
    font-weight: 700;
    text-decoration: none;
  }

  .ai-disclosure__link:hover,
  .ai-disclosure__link:focus-visible {
    text-decoration: underline;
  }

  @media (max-width: 42rem) {
    .ai-disclosure {
      padding: 0.9rem 1rem;
    }
  }
</style>
