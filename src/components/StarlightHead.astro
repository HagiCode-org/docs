---
import DefaultHead from '@astrojs/starlight/components/Head.astro';
import GoogleAnalytics from './GoogleAnalytics.astro';
import {
  DOCS_CONTENT_LAYOUT_ATTRIBUTE,
  DOCS_CONTENT_LAYOUT_MODES,
  DOCS_CONTENT_LAYOUT_STORAGE_KEY,
  DEFAULT_DOCS_CONTENT_LAYOUT_MODE,
} from '../lib/docs-content-layout.mjs';

const isValidPage = Astro.url.pathname !== '/404';
---

<script
  is:inline
  define:vars={{
    docsContentLayoutAttribute: DOCS_CONTENT_LAYOUT_ATTRIBUTE,
    docsContentLayoutModes: DOCS_CONTENT_LAYOUT_MODES,
    docsContentLayoutStorageKey: DOCS_CONTENT_LAYOUT_STORAGE_KEY,
    defaultDocsContentLayoutMode: DEFAULT_DOCS_CONTENT_LAYOUT_MODE,
  }}
>
  (() => {
    const root = document.documentElement;
    let mode = defaultDocsContentLayoutMode;

    try {
      const savedMode = localStorage.getItem(docsContentLayoutStorageKey);

      if (docsContentLayoutModes.includes(savedMode)) {
        mode = savedMode;
      }
    } catch {
      mode = defaultDocsContentLayoutMode;
    }

    root.setAttribute(docsContentLayoutAttribute, mode);
  })();
</script>
<DefaultHead />
{isValidPage && (
  <>
    <meta name="baidu-site-verification" content="codeva-A9s3yT3z5m" />
    <script is:inline src="/lang-redirect.js"></script>
    <GoogleAnalytics />
  </>
)}
