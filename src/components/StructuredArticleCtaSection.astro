---
import { localizeDocsHref } from '@/lib/articles.mjs';

const { cta = {}, locale = 'zh-CN' } = Astro.props;
const links = [cta.primary, cta.secondary].filter(Boolean);
---

{links.length > 0 ? (
  <section class="structured-article-cta">
    {cta.primary ? <a class="primary" href={localizeDocsHref(cta.primary.href, locale)}>{cta.primary.label}</a> : null}
    {cta.secondary ? <a class="secondary" href={localizeDocsHref(cta.secondary.href, locale)}>{cta.secondary.label}</a> : null}
  </section>
) : null}

<style>
  .structured-article-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .structured-article-cta a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.9rem;
    padding: 0.72rem 1.1rem;
    border-radius: 0.95rem;
    border: 1px solid transparent;
    text-decoration: none;
    font-weight: 600;
    line-height: 1.2;
    box-shadow: 0 10px 26px rgb(37 99 235 / 0.08);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .structured-article-cta a::after {
    content: '->';
    font-size: 0.82em;
  }

  .structured-article-cta a:hover {
    transform: translateY(-1px);
  }

  .structured-article-cta .primary {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--sl-color-accent) 88%, white),
      var(--sl-color-accent)
    );
    color: var(--sl-color-white);
    box-shadow: 0 14px 30px rgb(37 99 235 / 0.16);
  }

  .structured-article-cta .secondary {
    border-color: var(--sl-color-gray-5);
    color: var(--sl-color-text);
    background: color-mix(in srgb, var(--sl-color-bg) 95%, var(--sl-color-bg-nav) 5%);
  }

  .structured-article-cta .secondary:hover {
    border-color: color-mix(in srgb, var(--sl-color-accent) 28%, var(--sl-color-gray-5));
    color: var(--sl-color-accent-high);
  }

  @media (prefers-reduced-motion: reduce) {
    .structured-article-cta a {
      transition: none;
    }

    .structured-article-cta a:hover {
      transform: none;
    }
  }
</style>
