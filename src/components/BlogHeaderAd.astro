---
/**
 * 博客文章开头广告组件
 * 在博客文章标题之后、正文之前显示推广卡片
 *
 * 使用动态配置从 Presets JSON 读取推广内容
 */
import { getPromoContent } from '@/utils/promoConfig';
import { getLink } from '@shared/links';
import { resolveDocsLocale, type DocsLocale } from '@/lib/i18n';
import type { PromoContent } from '@/types/promo';

interface Props {
  /** 是否隐藏广告 */
  hideAd?: boolean;
  /** 当前语言（Starlight locale） */
  locale?: string;
}

const { hideAd = false, locale } = Astro.props;
const currentLocale: DocsLocale = resolveDocsLocale(Astro.currentLocale, locale, Astro.locals?.starlightRoute?.locale);

const localizedText = currentLocale === 'en'
  ? {
      fallbackTitle: 'Official Updates',
      fallbackDescription: 'Latest official updates and deployment guide for Hagicode.',
      fallbackButton: 'View Guide',
      fallbackBadge: 'Official',
    }
  : {
      fallbackTitle: '官方动态',
      fallbackDescription: '获取 Hagicode 最新官方动态与部署指南。',
      fallbackButton: '查看指南',
      fallbackBadge: '官方',
    };

// 如果设置隐藏广告，则不渲染
if (hideAd) {
  return null;
}

// 获取启用的推广内容
const promos = getPromoContent();

const fallbackPromo: PromoContent = {
  providerId: 'official-updates',
  name: 'Hagicode',
  title: localizedText.fallbackTitle,
  description: localizedText.fallbackDescription,
  ctaLabel: localizedText.fallbackButton,
  ctaUrl: getLink('dockerCompose'),
  badge: localizedText.fallbackBadge,
};

const renderPromos = promos.length > 0 ? promos : [fallbackPromo];
---

<div class="blog-header-ad-container">
  {renderPromos.map((promo, index) => (
    <div class={`blog-header-ad ${index === 0 ? 'primary-promo' : ''}`}>
      <div class="ad-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
          <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
          <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
        </svg>
      </div>
      <div class="ad-content">
        <div class="ad-title">
          {promo.title}
          {promo.badge && <span class="ad-badge">{promo.badge}</span>}
        </div>
        <div class="ad-description">
          {promo.description}
        </div>
      </div>
      <a
        href={promo.ctaUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="ad-button"
      >
        {promo.ctaLabel}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  ))}
</div>

<style>
  .blog-header-ad-container {
    --ad-primary: var(--color-primary, var(--sl-color-accent, #0080ff));
    --ad-secondary: var(--color-secondary, var(--sl-color-accent-high, #00cccc));
    --ad-border: var(--sl-color-gray-5, #4b5563);
    --ad-text-high: var(--sl-color-text-high, #e5e7eb);
    --ad-text-normal: var(--sl-color-text, #cbd5e1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-block-end: 1.5rem;
  }

  .blog-header-ad {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--sl-radius-md);
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--ad-primary) 8%, transparent),
      color-mix(in srgb, var(--ad-secondary) 5%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--ad-primary) 20%, var(--ad-border));
    color: var(--ad-text-high);
  }

  .primary-promo {
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--ad-primary) 10%, transparent),
      color-mix(in srgb, var(--ad-secondary) 7%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--ad-primary) 25%, var(--ad-border));
  }

  .ad-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--sl-radius-sm);
    background: linear-gradient(135deg, var(--ad-primary), var(--ad-secondary));
    color: white;
  }

  .ad-content {
    flex: 1;
    min-width: 0;
  }

  .ad-title {
    font-weight: 600;
    color: var(--ad-text-high);
    margin-block-end: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    -webkit-text-fill-color: currentColor;
  }

  .ad-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: var(--sl-radius-sm);
    background: color-mix(in srgb, var(--ad-primary) 20%, transparent);
    color: var(--ad-primary);
  }

  .ad-description {
    font-size: 0.875rem;
    color: var(--ad-text-normal);
    line-height: 1.5;
    -webkit-text-fill-color: currentColor;
  }

  .ad-button {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: var(--sl-radius-sm);
    background: linear-gradient(135deg, var(--sl-color-accent, #0080FF), var(--sl-color-accent-high, #00CCCC));
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ad-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 128, 255, 0.25);
  }

  .ad-button svg {
    transition: transform 0.2s ease;
  }

  .ad-button:hover svg {
    transform: translateX(2px);
  }

  /* 响应式优化 */
  @media (max-width: 640px) {
    .blog-header-ad-container {
      flex-direction: column;
    }

    .blog-header-ad {
      flex-direction: column;
    }

    .ad-button {
      align-self: flex-start;
    }
  }

  /* 减少动画偏好 */
  @media (prefers-reduced-motion: reduce) {
    .ad-button,
    .ad-button svg {
      transition: none !important;
    }

    .ad-button:hover {
      transform: none;
    }

    .ad-button:hover svg {
      transform: none;
    }
  }
</style>
