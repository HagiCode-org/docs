---
import { getStructuredArticleViewModel } from '@/lib/articles.mjs';
import StructuredArticleBlocks from './StructuredArticleBlocks.astro';
import StructuredArticleCtaSection from './StructuredArticleCtaSection.astro';
import StructuredArticleMetaRow from './StructuredArticleMetaRow.astro';

const locale = typeof Astro.props.locale === 'string' ? Astro.props.locale : 'zh-CN';
const slug = typeof Astro.props.slug === 'string' ? Astro.props.slug : '';
const article = getStructuredArticleViewModel(slug, locale);
const hasInlineCtaGroup = article.sections.some((section) =>
  section.blocks.some((block) => block.type === 'cta-group')
);
---

<section class="structured-article-page">
  <p class="structured-article-summary">{article.summary}</p>
  <StructuredArticleMetaRow
    requestedLocale={article.requestedLocale}
    resolvedLocale={article.resolvedLocale}
    updatedAt={article.updatedAt}
    usedFallback={article.usedFallback}
  />

  <div class="structured-article-sections">
    {article.sections.map((section) => (
      <section id={section.id} class="structured-article-section">
        <header>
          <h2>{section.title}</h2>
        </header>
        <StructuredArticleBlocks blocks={section.blocks} locale={article.requestedLocale} />
      </section>
    ))}
  </div>

  {!hasInlineCtaGroup ? (
    <StructuredArticleCtaSection cta={article.cta} locale={article.requestedLocale} />
  ) : null}
</section>

<style>
  .structured-article-page {
    display: grid;
    gap: 1rem;
  }

  .structured-article-summary {
    margin: 0;
    color: var(--sl-color-text-2);
    max-width: 60rem;
  }

  .structured-article-sections {
    display: grid;
    gap: 1.25rem;
  }

  .structured-article-section {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    padding: 1.2rem;
    background: color-mix(in srgb, var(--sl-color-bg) 96%, var(--sl-color-bg-nav) 4%);
  }

  .structured-article-section h2 {
    margin: 0;
    scroll-margin-top: calc(var(--sl-nav-height) + 5rem);
  }

  @media (max-width: 720px) {
    .structured-article-section {
      padding: 1rem;
    }
  }
</style>
