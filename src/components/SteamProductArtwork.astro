---
import type { DocsSteamProduct } from '@/lib/steam-products';

interface Props {
  product: DocsSteamProduct;
  ratio?: 'wide' | 'compact';
}

const { product, ratio = 'wide' } = Astro.props;
const hasImage = Boolean(product.image?.src);
---

<figure class:list={['steam-product-artwork', `steam-product-artwork--${ratio}`]} data-product-key={product.key}>
  {hasImage ? (
    <img
      src={product.image!.src}
      alt={product.image!.alt || product.title}
      width={product.image!.width}
      height={product.image!.height}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <span class="steam-product-artwork__fallback" role="img" aria-label={product.title}>
      <span>{product.title}</span>
    </span>
  )}
  <figcaption class="steam-product-artwork__caption">{product.title}</figcaption>
</figure>

<style>
  .steam-product-artwork {
    margin: 1.25rem 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 20%, var(--sl-color-gray-5));
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg) 88%, var(--sl-color-accent) 12%);
    box-shadow: 0 16px 34px color-mix(in srgb, var(--sl-color-black) 14%, transparent);
  }

  .steam-product-artwork--compact {
    max-width: 34rem;
  }

  .steam-product-artwork img,
  .steam-product-artwork__fallback {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .steam-product-artwork img {
    height: auto;
    object-fit: cover;
  }

  .steam-product-artwork__fallback {
    display: grid;
    min-height: 12rem;
    place-items: center;
    padding: 1rem;
    color: var(--sl-color-text-high);
    font-weight: 800;
    text-align: center;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 84%, var(--sl-color-accent-low) 16%);
  }

  .steam-product-artwork__caption {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
