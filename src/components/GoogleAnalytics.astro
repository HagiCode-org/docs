---
/**
 * Google Analytics 4 page-view bootstrap.
 * This integration intentionally stays at baseline page access tracking only;
 * custom events remain out of scope for this change.
 */
const measurementId = 'G-9R5WR99PHM';
const shouldLoadGoogleAnalytics = import.meta.env.PROD;
const googleAnalyticsScriptUrl =
  `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
---

{shouldLoadGoogleAnalytics && (
  <>
    <script async src={googleAnalyticsScriptUrl}></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9R5WR99PHM');
    </script>
  </>
)}
