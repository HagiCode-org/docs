---
import releaseNotesIndex from '../data/release-notes.index.json';
import {
  getReleaseNotesLandingCopy,
  getReleaseNotesLandingEntries,
} from '../lib/release-notes.mjs';

const locale = Astro.props.locale === 'en' ? 'en' : 'zh-CN';
const copy = getReleaseNotesLandingCopy(locale);
const entries = getReleaseNotesLandingEntries(releaseNotesIndex, locale);
---

<section class="release-notes-landing">
  <p class="release-notes-intro">{copy.intro}</p>

  {entries.length === 0 ? (
    <div class="release-notes-empty">
      <p>{copy.empty}</p>
    </div>
  ) : (
    <div class="release-notes-list">
      {entries.map((entry) => (
        <article class="release-notes-card">
          <header class="release-notes-card-header">
            <div>
              <h2>{entry.tag}</h2>
              <p class="release-notes-summary">{entry.summary}</p>
            </div>
            <time datetime={entry.releaseDate}>{entry.releaseDate}</time>
          </header>

          <p class="release-notes-meta">
            <span>{entry.repositoryCount} {copy.repositoryLabel}</span>
            <span>{entry.totalCommitCount} {copy.commitLabel}</span>
          </p>

          <div class="release-notes-actions">
            <a class="primary" href={entry.primaryRoute}>
              {copy.readPrimary}
            </a>
            <a class="secondary" href={entry.secondaryRoute}>
              {copy.readSecondary}
            </a>
          </div>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  .release-notes-landing {
    display: grid;
    gap: 1rem;
  }

  .release-notes-intro,
  .release-notes-empty p {
    margin: 0;
    color: var(--sl-color-text-2);
  }

  .release-notes-empty,
  .release-notes-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.02), rgb(255 255 255 / 0.08)),
      var(--sl-color-bg);
    box-shadow: 0 10px 30px rgb(15 23 42 / 0.06);
  }

  .release-notes-empty {
    padding: 1.25rem;
  }

  .release-notes-list {
    display: grid;
    gap: 1rem;
  }

  .release-notes-card {
    padding: 1.25rem;
  }

  .release-notes-card-header {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: flex-start;
  }

  .release-notes-card-header h2,
  .release-notes-summary,
  .release-notes-meta {
    margin: 0;
  }

  .release-notes-card-header h2 {
    font-size: 1.1rem;
  }

  .release-notes-card-header time {
    white-space: nowrap;
    font-size: 0.95rem;
    color: var(--sl-color-text-2);
  }

  .release-notes-summary {
    margin-top: 0.5rem;
    color: var(--sl-color-text-2);
  }

  .release-notes-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--sl-color-text-2);
  }

  .release-notes-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .release-notes-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .release-notes-actions a:hover {
    transform: translateY(-1px);
  }

  .release-notes-actions .primary {
    background: var(--sl-color-accent);
    color: var(--sl-color-white);
  }

  .release-notes-actions .secondary {
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-text);
  }

  @media (max-width: 720px) {
    .release-notes-card-header {
      flex-direction: column;
    }
  }
</style>
