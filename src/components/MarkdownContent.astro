---
/**
 * 自定义 MarkdownContent 组件
 * 包装 starlight-blog 的 MarkdownContent 组件，添加广告支持和图片灯箱
 *
 * 此组件基于 starlight-blog 的 MarkdownContent 组件，添加了以下功能：
 * - 在博客文章开头显示 BlogHeaderAd 广告
 * - 在博客文章结尾显示 BlogFooterAd 广告
 * - 支持通过 frontmatter 的 hideAd 属性控制广告显示
 * - 博客广告统一从 index promotion 数据源加载一次并复用
 * - 为所有页面添加图片灯箱功能
 */
import Default from '@astrojs/starlight/components/MarkdownContent.astro'
import StarlightBlogMarkdownContent from '@/integrations/starlight-blog-no-tags/components/starlight/MarkdownContent.astro'
import { resolveBlogAdProps } from '@/lib/blog-promotions'

import AIDisclosureNotices from './AIDisclosureNotices.astro'
import BlogHeaderAd from './BlogHeaderAd.astro'
import BlogFooterAd from './BlogFooterAd.astro'
import ImageLightbox from './ImageLightbox.tsx'
import { resolveDocsLocale } from '@/lib/i18n'

const route = Astro.locals?.starlightRoute
const id = route?.id ?? ''
const locale = route?.locale
const currentLocale = resolveDocsLocale(Astro.currentLocale, locale)

const localePrefix = locale && locale !== 'root' ? `${locale}/` : ''
const normalizedId = localePrefix && id.startsWith(localePrefix) ? id.slice(localePrefix.length) : id

const isBlogPost = /^blog\/\d{4}-\d{2}-\d{2}-[^/]+$/.test(normalizedId)
const blogPosts = Astro.locals.starlightBlog?.posts ?? []
const currentPost = isBlogPost
  ? blogPosts.find((post) => {
      const postId = post.entry.id
      return postId === id || postId === normalizedId || `en/${postId}` === id
    })
  : undefined
const currentEntry = currentPost?.entry ?? route?.entry

// 获取 hideAd 设置
// 从 starlightBlog 数据中查找当前文章，然后获取 hideAd 属性
let hideAd = false
if (isBlogPost && currentEntry) {
  hideAd = currentEntry.data.hideAd ?? false
}

const blogAdProps = await resolveBlogAdProps({
  isBlogPost,
  hideAd,
  locale: currentLocale,
})
---

{
  isBlogPost ? (
    <div class="blog-post-wrapper">
      <BlogHeaderAd {...blogAdProps} />
      <StarlightBlogMarkdownContent>
        {currentEntry && (
          <AIDisclosureNotices
            isAITranslation={currentEntry.data.isAITranslation}
            isAIAuthor={currentEntry.data.isAIAuthor}
            locale={currentLocale}
            pathname={Astro.url.pathname}
          />
        )}
        <slot />
      </StarlightBlogMarkdownContent>
      <BlogFooterAd {...blogAdProps} />
    </div>
  ) : (
    // 对于非博客页面，使用默认的 Starlight MarkdownContent 组件
    <Default>
      {currentEntry && (
        <AIDisclosureNotices
          isAITranslation={currentEntry.data.isAITranslation}
          isAIAuthor={currentEntry.data.isAIAuthor}
          locale={currentLocale}
          pathname={Astro.url.pathname}
        />
      )}
      <slot />
    </Default>
  )
}

<!-- ImageLightbox component for all pages -->
<ImageLightbox client:only="react" />

<style>
  .blog-post-wrapper {
    /* 确保内容正常显示 */
  }
</style>
