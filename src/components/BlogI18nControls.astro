---
import { DOCS_LOCALE_RESOURCES } from '../i18n/generated/docs-locale-resources.mjs';
import {
  BLOG_LANGUAGE_OPTIONS,
  buildBlogPostRoutePath,
  buildBlogRoutePath,
  getAllBlogRssLinks,
  getBlogLanguageByRouteLocale,
  type BlogLanguageCode,
} from '../lib/blog-i18n';

type Props = {
  routeLocale?: string;
  slug?: string;
};

const { routeLocale = 'root', slug } = Astro.props;
const currentLanguage = getBlogLanguageByRouteLocale(routeLocale) ?? BLOG_LANGUAGE_OPTIONS[0];
const resources = DOCS_LOCALE_RESOURCES[currentLanguage.code]?.blog?.rss ?? DOCS_LOCALE_RESOURCES['en-US'].blog.rss;
const languageFeedLabels = resources.languageFeeds ?? {};

function targetPath(code: BlogLanguageCode) {
  return slug ? buildBlogPostRoutePath(code, slug) : buildBlogRoutePath(code, '/blog/');
}
---

<aside class="blog-i18n-controls" aria-label={resources.subscribeTitle}>
  <div class="blog-i18n-section">
    <p class="blog-i18n-heading">{resources.languageSection}</p>
    <div class="blog-language-list">
      {BLOG_LANGUAGE_OPTIONS.map((language) => (
        <a
          class:list={[
            'blog-language-link',
            { 'is-current': language.code === currentLanguage.code },
          ]}
          href={targetPath(language.code)}
          lang={language.code}
          aria-current={language.code === currentLanguage.code ? 'page' : undefined}
          title={language.nativeName}
        >
          <span class="blog-language-short">{language.shortLabel}</span>
          <span class="blog-language-name">{language.nativeName}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="blog-i18n-section">
    <p class="blog-i18n-heading">{resources.feedSection}</p>
    <div class="blog-rss-list">
      {getAllBlogRssLinks().map((feed) => (
        <a class="blog-rss-link" href={feed.path}>
          {feed.scope === 'all'
            ? resources.allLanguages
            : languageFeedLabels[feed.scope] ?? feed.label}
        </a>
      ))}
    </div>
  </div>
</aside>

<style>
  .blog-i18n-controls {
    display: grid;
    gap: 0.85rem;
    margin: 1rem 0 1.25rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent-low) 45%, transparent);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg-sidebar) 90%, var(--sl-color-accent-low) 10%);
  }

  .blog-i18n-heading {
    margin: 0 0 0.45rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .blog-language-list,
  .blog-rss-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .blog-language-link,
  .blog-rss-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 2rem;
    padding: 0.32rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 68%, transparent);
    border-radius: 999px;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    text-decoration: none;
    background: color-mix(in srgb, var(--sl-color-bg) 78%, transparent);
  }

  .blog-language-link:hover,
  .blog-rss-link:hover,
  .blog-language-link.is-current {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-text-high);
    background: color-mix(in srgb, var(--sl-color-accent-low) 34%, var(--sl-color-bg));
  }

  .blog-language-short {
    font-weight: 800;
  }

  .blog-language-name {
    opacity: 0.86;
  }

  @media (max-width: 42rem) {
    .blog-i18n-controls {
      padding: 0.85rem;
    }

    .blog-language-name {
      display: none;
    }
  }
</style>
