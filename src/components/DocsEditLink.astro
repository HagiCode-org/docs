---
import { Icon } from "@astrojs/starlight/components";

import { resolveDocsEditLink } from "@/lib/docs-edit-link";

interface Props {
  placement: "header" | "footer";
}

const { placement } = Astro.props;
const editLink = resolveDocsEditLink(Astro.locals.starlightRoute);
---

{
  editLink.isVisible && (
    <a
      href={editLink.href}
      class:list={[
        "docs-edit-link",
        `docs-edit-link--${placement}`,
        "print:hidden",
      ]}
      data-docs-edit-link=""
      data-docs-edit-link-placement={placement}
    >
      <span class="docs-edit-link__icon" aria-hidden="true">
        <Icon name="pencil" size="1rem" />
      </span>
      <span class="docs-edit-link__label">{Astro.locals.t("page.editLink")}</span>
      <span class="docs-edit-link__icon docs-edit-link__icon--external" aria-hidden="true">
        <Icon name="external" size="0.9rem" />
      </span>
    </a>
  )
}
