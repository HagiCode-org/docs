---
import {
  DOCS_CONTENT_LAYOUT_BUTTON_SELECTOR,
  DOCS_CONTENT_LAYOUT_NARROW,
  DOCS_CONTENT_LAYOUT_STORAGE_KEY,
  DOCS_CONTENT_LAYOUT_WIDE,
  DEFAULT_DOCS_CONTENT_LAYOUT_MODE,
} from '../lib/docs-content-layout.mjs';

const { locale = 'root' } = Astro.props;
const isEnglish = locale === 'en';

const copy = isEnglish
  ? {
      label: 'Content layout',
      wide: 'Wide',
      narrow: 'Narrow',
    }
  : {
      label: '正文宽度',
      wide: '宽版',
      narrow: '窄版',
    };

const modes = [
  { value: DOCS_CONTENT_LAYOUT_WIDE, label: copy.wide },
  { value: DOCS_CONTENT_LAYOUT_NARROW, label: copy.narrow },
];
---

<div class="docs-content-layout-toggle" data-docs-content-layout-toggle role="group" aria-label={copy.label}>
  {modes.map((mode) => (
    <button
      type="button"
      class="docs-content-layout-toggle__option"
      data-docs-content-layout-mode={mode.value}
      aria-pressed={mode.value === DEFAULT_DOCS_CONTENT_LAYOUT_MODE ? 'true' : 'false'}
    >
      {mode.label}
    </button>
  ))}
</div>

<script>
  import {
    DOCS_CONTENT_LAYOUT_BUTTON_SELECTOR,
    DOCS_CONTENT_LAYOUT_STORAGE_KEY,
    getDocsContentLayout,
    normalizeDocsContentLayout,
    syncDocsContentLayout,
    syncDocsContentLayoutToggleState,
  } from '../lib/docs-content-layout.mjs';

  const root = document.documentElement;
  const toggles = Array.from(document.querySelectorAll('[data-docs-content-layout-toggle]'));

  const syncAllToggles = (mode = getDocsContentLayout(root)) => {
    toggles.forEach((toggle) => syncDocsContentLayoutToggleState(toggle, mode));
  };

  const setMode = (value) => {
    const nextMode = syncDocsContentLayout(root, window.localStorage, value);
    syncAllToggles(nextMode);
  };

  syncAllToggles();

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof Element)) {
        return;
      }

      const button = target.closest(DOCS_CONTENT_LAYOUT_BUTTON_SELECTOR);

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      setMode(normalizeDocsContentLayout(button.dataset.docsContentLayoutMode));
    });
  });

  window.addEventListener('storage', (event) => {
    if (event.key && event.key !== DOCS_CONTENT_LAYOUT_STORAGE_KEY) {
      return;
    }

    syncAllToggles(syncDocsContentLayout(root, window.localStorage));
  });
</script>

<style>
  @layer starlight.core {
    .docs-content-layout-toggle {
      display: none;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 999px;
      background: var(--sl-color-bg-nav);
    }

    .docs-content-layout-toggle__option {
      appearance: none;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: var(--sl-color-gray-3);
      cursor: pointer;
      font: inherit;
      font-size: var(--sl-text-xs);
      font-weight: 600;
      line-height: 1;
      padding: 0.45rem 0.75rem;
      transition:
        background-color var(--sl-transition-fast),
        color var(--sl-transition-fast),
        box-shadow var(--sl-transition-fast);
      white-space: nowrap;
    }

    .docs-content-layout-toggle__option:hover {
      color: var(--sl-color-text);
    }

    .docs-content-layout-toggle__option:focus-visible {
      outline: 2px solid var(--sl-color-accent);
      outline-offset: 2px;
    }

    :global(html[data-docs-content-layout='wide'])
      .docs-content-layout-toggle__option[data-docs-content-layout-mode='wide'],
    :global(html[data-docs-content-layout='narrow'])
      .docs-content-layout-toggle__option[data-docs-content-layout-mode='narrow'] {
      background: var(--sl-color-bg-accent);
      color: var(--sl-color-text-invert);
      box-shadow: var(--sl-shadow-sm);
    }

    @media (min-width: 64rem) {
      .docs-content-layout-toggle {
        display: inline-flex;
      }
    }
  }
</style>
