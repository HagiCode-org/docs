---
import { getManagedTipsArticle } from '../lib/tips.mjs';

const locale = typeof Astro.props.locale === 'string' ? Astro.props.locale : 'zh-CN';
const { copy, groups, updatedAt, totalLabel, totalTips, dataLocale, sourceUrl } = getManagedTipsArticle(locale);
---

<section class="tips-article">
  <p class="tips-intro">{copy.intro}</p>

  {totalTips === 0 ? (
    <div class="tips-empty">
      <p>{copy.empty}</p>
    </div>
  ) : (
    <>
      <div class="tips-meta" aria-label="tips metadata">
        {updatedAt ? <span>{copy.updatedAtLabel}: {updatedAt}</span> : null}
        <span>{totalLabel}</span>
        {dataLocale ? <span>{copy.dataLocaleLabel}: {dataLocale}</span> : null}
        {sourceUrl ? (
          <a href={sourceUrl} target="_blank" rel="noreferrer">{copy.sourceLabel}</a>
        ) : null}
      </div>

      <div class="tips-groups">
        {groups.map((group) => (
          <section class="tips-group">
            <header class="tips-group-header">
              <div>
                <h2 id={`tips-${group.id}`}>{group.label}</h2>
              </div>
              <p>{group.countLabel}</p>
            </header>

            <ol>
              {group.tips.map((tip) => (
                <li>
                  <p>{tip.text}</p>
                  {tip.id ? <code>{tip.id}</code> : null}
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </>
  )}
</section>

<style>
  .tips-article {
    display: grid;
    gap: 1rem;
  }

  .tips-intro,
  .tips-empty p,
  .tips-group-header p,
  .tips-group li p {
    margin: 0;
  }

  .tips-intro,
  .tips-empty p {
    color: var(--sl-color-text-2);
    max-width: 58rem;
  }

  .tips-empty,
  .tips-group {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg) 94%, var(--sl-color-bg-nav) 6%);
    box-shadow: 0 12px 28px rgb(15 23 42 / 0.06);
  }

  .tips-empty {
    padding: 1.25rem;
  }

  .tips-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    color: var(--sl-color-text-2);
    font-size: 0.9rem;
  }

  .tips-meta span,
  .tips-meta a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 88%, transparent);
    text-decoration: none;
    color: inherit;
  }

  .tips-meta a:hover {
    color: var(--sl-color-text);
    border-color: var(--sl-color-accent);
  }

  .tips-groups {
    display: grid;
    gap: 1.25rem;
  }

  .tips-group {
    padding: 1.35rem;
  }

  .tips-group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .tips-group-header h2 {
    margin: 0;
    scroll-margin-top: calc(var(--sl-nav-height) + 5rem);
  }

  .tips-group-header p {
    color: var(--sl-color-text-2);
    white-space: nowrap;
  }

  .tips-group ol {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.8rem;
  }

  .tips-group li {
    display: grid;
    gap: 0.35rem;
  }

  .tips-group code {
    width: fit-content;
    color: var(--sl-color-text-2);
    font-size: 0.82rem;
  }

  @media (max-width: 720px) {
    .tips-group {
      padding: 1.05rem;
    }

    .tips-group-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
