---
import DocsEditLink from "./DocsEditLink.astro";
import DocsContentLayoutToggle from "./DocsContentLayoutToggle.astro";
import { resolveDocsLocale } from "@/lib/i18n";

const PAGE_TITLE_ID = "_top";
const docsLocale = resolveDocsLocale(Astro.locals.starlightRoute?.locale);
---

<div class="docs-page-title">
  <h1 id={PAGE_TITLE_ID}>{Astro.locals.starlightRoute.entry.data.title}</h1>
  <div class="docs-page-title__actions">
    <DocsEditLink placement="header" />
    <DocsContentLayoutToggle locale={docsLocale} />
  </div>
</div>

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }

    .docs-page-title__actions {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.625rem;
      margin-top: 1rem;
    }
  }
</style>
