---
import { localizeDocsHref } from '@/lib/articles.mjs';

const { blocks = [], locale = 'zh-CN' } = Astro.props;
---

{blocks.map((block) => {
  switch (block.type) {
    case 'rich-text':
      return (
        <div class="structured-block structured-rich-text">
          {block.content.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      );
    case 'bullet-list':
      return (
        <ul class="structured-block structured-bullet-list">
          {block.items.map((item) => <li>{item}</li>)}
        </ul>
      );
    case 'capability-list':
      return (
        <div class="structured-block structured-capability-list">
          {block.items.map((item) => (
            <article class="capability-card">
              <h3>{item.title}</h3>
              {item.content.map((paragraph) => <p>{paragraph}</p>)}
              {item.bullets?.length ? (
                <ul>
                  {item.bullets.map((entry) => <li>{entry}</li>)}
                </ul>
              ) : null}
            </article>
          ))}
        </div>
      );
    case 'comparison-grid':
      return (
        <div class="structured-block structured-comparison-grid">
          {block.items.map((item) => (
            <article class="comparison-card">
              <h3>{item.label}</h3>
              <dl>
                <div>
                  <dt>Agent</dt>
                  <dd>{item.agent}</dd>
                </div>
                <div>
                  <dt>HagiCode</dt>
                  <dd>{item.hagicode}</dd>
                </div>
                {item.combinedValue ? (
                  <div>
                    <dt>Combined value</dt>
                    <dd>{item.combinedValue}</dd>
                  </div>
                ) : null}
              </dl>
            </article>
          ))}
        </div>
      );
    case 'callout':
      return (
        <aside class={`structured-block structured-callout tone-${block.tone}`}>
          {block.title ? <h3>{block.title}</h3> : null}
          {block.content.map((paragraph) => <p>{paragraph}</p>)}
        </aside>
      );
    case 'cta-group':
      return (
        <div class="structured-block structured-cta-group">
          {block.items.map((item) => (
            <a class={item.variant === 'secondary' ? 'secondary' : 'primary'} href={localizeDocsHref(item.href, locale)}>{item.label}</a>
          ))}
        </div>
      );
    default:
      throw new Error(`Unsupported structured article block type: ${block.type}`);
  }
})}

<style>
  .structured-block p,
  .structured-block ul,
  .structured-block dl,
  .structured-block h3 {
    margin: 0;
  }

  .structured-rich-text,
  .structured-capability-list,
  .structured-comparison-grid,
  .structured-callout,
  .structured-cta-group,
  .structured-bullet-list {
    display: grid;
    gap: 0.9rem;
  }

  .structured-capability-list,
  .structured-comparison-grid {
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }

  .capability-card,
  .comparison-card,
  .structured-callout {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    padding: 1rem;
    background: color-mix(in srgb, var(--sl-color-bg) 95%, var(--sl-color-bg-nav) 5%);
  }

  .capability-card ul,
  .structured-bullet-list {
    padding-left: 1.2rem;
  }

  .comparison-card dl {
    display: grid;
    gap: 0.75rem;
  }

  .comparison-card dt {
    font-size: 0.85rem;
    color: var(--sl-color-text-2);
  }

  .comparison-card dd {
    margin: 0.2rem 0 0;
  }

  .structured-callout.tone-success {
    border-color: color-mix(in srgb, var(--sl-color-accent) 35%, var(--sl-color-gray-5));
  }

  .structured-callout.tone-warning {
    border-color: color-mix(in srgb, #f59e0b 55%, var(--sl-color-gray-5));
  }

  .structured-cta-group {
    grid-template-columns: repeat(auto-fit, minmax(13rem, max-content));
  }

  .structured-cta-group a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.9rem;
    padding: 0.72rem 1.1rem;
    border-radius: 0.95rem;
    border: 1px solid transparent;
    text-decoration: none;
    font-weight: 600;
    line-height: 1.2;
    box-shadow: 0 10px 26px rgb(37 99 235 / 0.08);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .structured-cta-group a::after {
    content: '->';
    font-size: 0.82em;
  }

  .structured-cta-group a:hover {
    transform: translateY(-1px);
  }

  .structured-cta-group a.primary {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--sl-color-accent) 88%, white),
      var(--sl-color-accent)
    );
    color: var(--sl-color-white);
    box-shadow: 0 14px 30px rgb(37 99 235 / 0.16);
  }

  .structured-cta-group a.secondary {
    border-color: var(--sl-color-gray-5);
    color: var(--sl-color-text);
    background: color-mix(in srgb, var(--sl-color-bg) 94%, var(--sl-color-bg-nav) 6%);
  }

  .structured-cta-group a.secondary:hover {
    border-color: color-mix(in srgb, var(--sl-color-accent) 28%, var(--sl-color-gray-5));
    color: var(--sl-color-accent-high);
  }

  @media (prefers-reduced-motion: reduce) {
    .structured-cta-group a {
      transition: none;
    }

    .structured-cta-group a:hover {
      transform: none;
    }
  }
</style>
