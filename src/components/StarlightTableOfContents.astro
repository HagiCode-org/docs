---
import DefaultTableOfContents from '@astrojs/starlight/components/TableOfContents.astro';

import { getManagedReleaseNotesToc } from '../lib/release-notes.mjs';
import { isReleaseNotesRoutePath } from '../lib/i18n.ts';

const route = Astro.locals.starlightRoute;
const currentLocale = route?.locale === 'en' ? 'en' : 'zh-CN';
const isReleaseNotesLanding = isReleaseNotesRoutePath(Astro.url.pathname);
const tocItems = isReleaseNotesLanding ? getManagedReleaseNotesToc(currentLocale) : [];
---

{
  isReleaseNotesLanding ? (
    <>
      <starlight-toc data-min-h="2" data-max-h="2">
        <nav aria-labelledby="starlight__on-this-page">
          <h2 id="starlight__on-this-page">{Astro.locals.t('tableOfContents.onThisPage')}</h2>
          <ul class="release-notes-toc-list">
            {tocItems.map((item) => (
              <li>
                <a href={item.href}>
                  <span>{item.text}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </starlight-toc>
      <script type="module">import "@astrojs/starlight/components-internals/TableOfContents/starlight-toc";</script>
    </>
  ) : (
    <DefaultTableOfContents />
  )
}

<style>
  @layer starlight.core {
    .release-notes-toc-list {
      padding: 0;
      list-style: none;
      margin: 0;
    }

    .release-notes-toc-list a {
      --pad-inline: 0.5rem;
      display: block;
      border-radius: 0.25rem;
      padding-block: 0.25rem;
      padding-inline: var(--pad-inline);
      line-height: 1.25;
    }

    .release-notes-toc-list a[aria-current='true'] {
      color: var(--sl-color-text-accent);
    }
  }
</style>
