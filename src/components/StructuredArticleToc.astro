---
const { toc = [] } = Astro.props;
---

{toc.length > 0 ? (
  <nav class="structured-article-toc" aria-label="table of contents">
    <h2>Contents</h2>
    <ol>
      {toc.map((entry) => (
        <li><a href={`#${entry.id}`}>{entry.title}</a></li>
      ))}
    </ol>
  </nav>
) : null}

<style>
  .structured-article-toc {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    padding: 1.1rem 1.2rem;
    background: color-mix(in srgb, var(--sl-color-bg) 94%, var(--sl-color-bg-nav) 6%);
  }

  .structured-article-toc h2,
  .structured-article-toc ol {
    margin: 0;
  }

  .structured-article-toc ol {
    padding-left: 1.2rem;
    display: grid;
    gap: 0.55rem;
    margin-top: 0.8rem;
  }

  .structured-article-toc a {
    text-decoration: none;
  }
</style>
