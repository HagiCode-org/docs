---
type Props = {
  copy: {
    label: string;
    title: string;
    description: string;
  };
};

const { copy } = Astro.props;
---

<aside class="ai-disclosure ai-disclosure--author" aria-label={copy.title}>
  <p class="ai-disclosure__label">{copy.label}</p>
  <p class="ai-disclosure__title">{copy.title}</p>
  <p class="ai-disclosure__description">{copy.description}</p>
</aside>
