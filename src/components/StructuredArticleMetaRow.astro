---
const {
  requestedLocale,
  resolvedLocale,
  updatedAt,
  usedFallback = false,
} = Astro.props;

const locale = typeof requestedLocale === 'string' && requestedLocale.trim().length > 0
  ? requestedLocale
  : 'en-US';
const formattedUpdatedAt = formatUpdatedAt(updatedAt, locale);
const fallbackMessage = usedFallback
  ? buildFallbackMessage(locale, requestedLocale, resolvedLocale)
  : null;

function formatUpdatedAt(value, dateLocale) {
  if (typeof value !== 'string' || value.trim().length === 0) {
    return null;
  }

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value;
  }

  try {
    return new Intl.DateTimeFormat(dateLocale, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    }).format(date);
  } catch {
    return value;
  }
}

function getLanguageName(targetLocale, displayLocale) {
  if (typeof targetLocale !== 'string' || targetLocale.trim().length === 0) {
    return 'English';
  }

  try {
    const displayNames = new Intl.DisplayNames([displayLocale], { type: 'language' });
    return displayNames.of(targetLocale) ?? targetLocale;
  } catch {
    return targetLocale;
  }
}

function getMetaCopy(dateLocale) {
  const language = String(dateLocale ?? 'en-US').toLowerCase();

  if (language.startsWith('zh-hant')) {
    return {
      updatedLabel: '更新於',
      fallbackLabel: '內容語言提醒',
      buildFallbackText: (displayLanguage) => `此頁面暫時以 ${displayLanguage} 顯示，對應語系版本仍在準備中。`,
    };
  }

  if (language.startsWith('zh')) {
    return {
      updatedLabel: '更新于',
      fallbackLabel: '内容语言提示',
      buildFallbackText: (displayLanguage) => `当前页面暂时以${displayLanguage}显示，对应语种版本还在准备中。`,
    };
  }

  if (language.startsWith('de')) {
    return {
      updatedLabel: 'Aktualisiert',
      fallbackLabel: 'Hinweis zur Sprache',
      buildFallbackText: (displayLanguage) => `Diese Seite wird vorerst auf ${displayLanguage} angezeigt, die lokalisierte Fassung wird noch vorbereitet.`,
    };
  }

  if (language.startsWith('fr')) {
    return {
      updatedLabel: 'Mis a jour',
      fallbackLabel: 'Langue du contenu',
      buildFallbackText: (displayLanguage) => `Cette page est provisoirement affichee en ${displayLanguage}, la version localisee est encore en preparation.`,
    };
  }

  if (language.startsWith('es')) {
    return {
      updatedLabel: 'Actualizado',
      fallbackLabel: 'Idioma del contenido',
      buildFallbackText: (displayLanguage) => `Esta pagina se muestra temporalmente en ${displayLanguage} mientras se prepara la version localizada.`,
    };
  }

  if (language.startsWith('pt')) {
    return {
      updatedLabel: 'Atualizado',
      fallbackLabel: 'Idioma do conteudo',
      buildFallbackText: (displayLanguage) => `Esta pagina esta sendo exibida temporariamente em ${displayLanguage} enquanto a versao localizada e preparada.`,
    };
  }

  if (language.startsWith('ru')) {
    return {
      updatedLabel: 'Updated',
      fallbackLabel: 'Content language',
      buildFallbackText: (displayLanguage) => `This page is temporarily shown in ${displayLanguage} while the localized version is being prepared.`,
    };
  }

  if (language.startsWith('ja')) {
    return {
      updatedLabel: '更新日',
      fallbackLabel: 'コンテンツ言語',
      buildFallbackText: (displayLanguage) => `${displayLanguage} の内容を一時的に表示しています。対象言語版は準備中です。`,
    };
  }

  if (language.startsWith('ko')) {
    return {
      updatedLabel: '업데이트',
      fallbackLabel: '콘텐츠 언어',
      buildFallbackText: (displayLanguage) => `현재 이 페이지는 ${displayLanguage} 콘텐츠로 임시 표시되며, 현지화 버전은 준비 중입니다.`,
    };
  }

  return {
    updatedLabel: 'Updated',
    fallbackLabel: 'Content language',
    buildFallbackText: (displayLanguage) => `This page is temporarily shown in ${displayLanguage} while the localized version is being prepared.`,
  };
}

function buildFallbackMessage(dateLocale, routeLocale, dataLocale) {
  const copy = getMetaCopy(dateLocale);
  const displayLanguage = getLanguageName(dataLocale, routeLocale || dateLocale);
  return {
    label: copy.fallbackLabel,
    text: copy.buildFallbackText(displayLanguage),
  };
}

const copy = getMetaCopy(locale);
---

<div class="structured-article-meta" aria-label="article metadata">
  {formattedUpdatedAt ? (
    <span class="structured-article-meta__pill">{copy.updatedLabel}: {formattedUpdatedAt}</span>
  ) : null}

  {fallbackMessage ? (
    <p class="structured-article-meta__notice" role="note" aria-label={fallbackMessage.label}>
      {fallbackMessage.text}
    </p>
  ) : null}
</div>

<style>
  .structured-article-meta {
    display: grid;
    gap: 0.75rem;
  }

  .structured-article-meta__pill {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.28rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 90%, transparent);
    color: var(--sl-color-text-2);
    font-size: 0.9rem;
  }

  .structured-article-meta__notice {
    margin: 0;
    max-width: 62rem;
    padding: 0.9rem 1rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-5));
    border-radius: 1rem;
    background: color-mix(in srgb, var(--sl-color-accent-low) 42%, var(--sl-color-bg) 58%);
    color: var(--sl-color-text-1);
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .structured-article-meta__notice {
      padding: 0.85rem 0.95rem;
      border-radius: 0.9rem;
    }
  }
</style>
