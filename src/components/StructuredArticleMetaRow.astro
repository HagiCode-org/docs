---
const {
  requestedLocale,
  resolvedLocale,
  updatedAt,
  usedFallback = false,
} = Astro.props;
---

<div class="structured-article-meta" aria-label="article metadata">
  {updatedAt ? <span>Updated: {updatedAt}</span> : null}
  <span>Route locale: {requestedLocale}</span>
  <span>Data locale: {resolvedLocale}</span>
  {usedFallback ? <span>Fallback applied</span> : null}
</div>

<style>
  .structured-article-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    color: var(--sl-color-text-2);
    font-size: 0.9rem;
  }

  .structured-article-meta span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 88%, transparent);
  }
</style>
