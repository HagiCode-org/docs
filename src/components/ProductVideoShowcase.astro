---
interface VideoItem {
  bvid: string;
  title: string;
  description: string;
  url: string;
}

interface Props {
  locale?: 'zh-CN' | 'en';
}

const { locale = 'zh-CN' } = Astro.props;

const bundle = locale === 'en'
  ? {
      eyebrow: 'Real Product Walkthroughs',
      title: 'See Hagicode in real coding sessions',
      description:
        'Start with the core daily workflow, then jump into a playful AI side quest and a GPT Codex validation run inside Hagicode.',
      ctaLabel: 'Open on Bilibili',
      featuredLabel: 'Featured walkthrough',
      supportingLabel: 'Focused demo',
      videos: [
        {
          bvid: 'BV1pirZBuEzq',
          title: 'Daily Hagi Half-Hour: AI Multi-Task Programming Practice',
          description:
            "A guided overview of Hagicode's everyday workflow, agent orchestration, and the core experience new visitors should understand first.",
          url: 'https://www.bilibili.com/video/BV1pirZBuEzq/',
        },
        {
          bvid: 'BV1KxwMzxEVK',
          title: 'AI Playing Games While Coding',
          description:
            'A playful clip that shows how the assistant can stay lively and surprising during real coding sessions instead of feeling like a dry code generator.',
          url: 'https://www.bilibili.com/video/BV1KxwMzxEVK/',
        },
        {
          bvid: 'BV1yqPmzTEqP',
          title: 'GPT Codex in Hagicode: Live Trial',
          description:
            'A focused validation run of GPT Codex inside Hagicode so prospective users can judge how the model performs in the actual product.',
          url: 'https://www.bilibili.com/video/BV1yqPmzTEqP/',
        },
      ] satisfies VideoItem[],
    }
  : {
      eyebrow: '真实视频演示',
      title: '视频实测：看看 Hagicode 真正怎么工作',
      description:
        '先看原有基础视频，再补充趣味互动与 Codex 实测，三条精选视频一起帮你快速理解产品能力。',
      ctaLabel: '打开 Bilibili',
      featuredLabel: '主推荐视频',
      supportingLabel: '补充演示',
      videos: [
        {
          bvid: 'BV1pirZBuEzq',
          title: '每天哈基半小时,AI多任务编程实战',
          description:
            '用一条总览视频快速了解 Hagicode 的核心工作流、常见操作路径和多任务编程体验。',
          url: 'https://www.bilibili.com/video/BV1pirZBuEzq/',
        },
        {
          bvid: 'BV1KxwMzxEVK',
          title: 'AI 居然 写代码时 玩游戏',
          description:
            '展示 AI 在真实写代码过程中出现的有趣互动，让首页第一眼就更有记忆点。',
          url: 'https://www.bilibili.com/video/BV1KxwMzxEVK/',
        },
        {
          bvid: 'BV1yqPmzTEqP',
          title: 'GPT Codex in Hagicode 实测',
          description:
            '聚焦 GPT Codex 在 Hagicode 中的实际表现，帮助你判断模型接入后的真实效果。',
          url: 'https://www.bilibili.com/video/BV1yqPmzTEqP/',
        },
      ] satisfies VideoItem[],
    };
---

<section class="product-video-showcase" aria-labelledby={`product-video-showcase-${locale}`}>
  <div class="product-video-showcase__header">
    <span class="product-video-showcase__eyebrow">{bundle.eyebrow}</span>
    <h2 id={`product-video-showcase-${locale}`} class="product-video-showcase__title">{bundle.title}</h2>
    <p class="product-video-showcase__description">{bundle.description}</p>
  </div>

  <div class="product-video-showcase__grid">
    {bundle.videos.map((video, index) => {
      const isFeatured = index === 0;
      return (
        <article
          class:list={[
            'product-video-showcase__card',
            isFeatured && 'product-video-showcase__card--featured',
          ]}
        >
          <div class="product-video-showcase__player">
            <div class="product-video-showcase__frame">
              <iframe
                src={`https://player.bilibili.com/player.html?bvid=${video.bvid}&page=1&high_quality=1&danmaku=0&autoplay=0`}
                title={`Bilibili player: ${video.title}`}
                loading="lazy"
                allowfullscreen
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                sandbox="allow-forms allow-scripts allow-same-origin allow-presentation"
              />
            </div>
          </div>

          <div class="product-video-showcase__content">
            <span class="product-video-showcase__label">
              {isFeatured ? bundle.featuredLabel : bundle.supportingLabel}
            </span>
            <h3 class="product-video-showcase__card-title">{video.title}</h3>
            <p class="product-video-showcase__card-description">{video.description}</p>
            <a
              class="product-video-showcase__action"
              href={video.url}
              target="_blank"
              rel="noreferrer"
              aria-label={`${bundle.ctaLabel}: ${video.title}`}
            >
              {bundle.ctaLabel}
            </a>
          </div>
        </article>
      );
    })}
  </div>
</section>

<style>
  .product-video-showcase {
    position: relative;
    margin-top: 2.5rem;
    padding: 2rem 0 0.5rem;
  }

  .product-video-showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--sl-color-accent-high) 12%, transparent) 0, transparent 46%),
      linear-gradient(180deg, color-mix(in srgb, var(--sl-color-bg-nav) 68%, transparent), transparent 82%);
    pointer-events: none;
    z-index: 0;
  }

  .product-video-showcase__header,
  .product-video-showcase__grid {
    position: relative;
    z-index: 1;
  }

  .product-video-showcase__header {
    margin: 0 auto 1.75rem;
    max-width: 44rem;
    text-align: center;
  }

  .product-video-showcase__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 24%, transparent);
    background: color-mix(in srgb, var(--sl-color-bg-sidebar) 72%, transparent);
    color: var(--sl-color-text-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-video-showcase__title {
    margin: 1rem 0 0.75rem;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.12;
  }

  .product-video-showcase__description {
    margin: 0;
    color: var(--sl-color-text-secondary);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .product-video-showcase__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .product-video-showcase__card {
    display: grid;
    gap: 1rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 76%, transparent);
    border-radius: 1.5rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--sl-color-bg-nav) 94%, white 6%), color-mix(in srgb, var(--sl-color-bg-sidebar) 96%, transparent));
    box-shadow:
      0 22px 52px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.26);
  }

  :global([data-theme='dark']) .product-video-showcase__card {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--sl-color-bg-nav) 94%, #020617 6%), color-mix(in srgb, var(--sl-color-bg-sidebar) 96%, #020617 4%));
    box-shadow:
      0 24px 60px rgba(2, 6, 23, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .product-video-showcase__card--featured {
    grid-column: 1 / -1;
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.95fr);
    align-items: center;
  }

  .product-video-showcase__player,
  .product-video-showcase__content {
    min-width: 0;
  }

  .product-video-showcase__frame {
    position: relative;
    overflow: hidden;
    border-radius: 1.1rem;
    background: var(--sl-color-black);
    box-shadow: 0 16px 36px rgba(15, 23, 42, 0.18);
  }

  .product-video-showcase__frame::before {
    content: '';
    display: block;
    padding-bottom: 56.25%;
  }

  .product-video-showcase__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .product-video-showcase__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
  }

  .product-video-showcase__label {
    display: inline-flex;
    width: fit-content;
    padding: 0.36rem 0.72rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-accent-high) 14%, transparent);
    color: var(--sl-color-white);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .product-video-showcase__card-title {
    margin: 0;
    font-size: clamp(1.18rem, 2vw, 1.8rem);
    line-height: 1.2;
  }

  .product-video-showcase__card-description {
    margin: 0;
    color: var(--sl-color-text-secondary);
    line-height: 1.7;
  }

  .product-video-showcase__action {
    display: inline-flex;
    width: fit-content;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--sl-color-accent) 0%, var(--sl-color-accent-high) 100%);
    color: var(--sl-color-white);
    font-weight: 700;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease;
    box-shadow: 0 14px 32px rgba(14, 165, 233, 0.18);
    color: #fff !important;
    -webkit-text-fill-color: #fff;
  }

  .product-video-showcase__action:link,
  .product-video-showcase__action:visited,
  .product-video-showcase__action:hover,
  .product-video-showcase__action:active {
    color: #fff !important;
    -webkit-text-fill-color: #fff;
    text-decoration: none;
  }

  .product-video-showcase__action:hover {
    transform: translateY(-1px);
    box-shadow: 0 18px 36px rgba(14, 165, 233, 0.24);
  }

  .product-video-showcase__action:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--sl-color-accent) 38%, transparent);
    outline-offset: 3px;
  }

  @media (max-width: 62rem) {
    .product-video-showcase__grid {
      grid-template-columns: 1fr;
    }

    .product-video-showcase__card--featured {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 40rem) {
    .product-video-showcase {
      margin-top: 2rem;
      padding-top: 1.5rem;
    }

    .product-video-showcase__card {
      padding: 0.8rem;
      border-radius: 1.2rem;
    }

    .product-video-showcase__frame {
      border-radius: 0.95rem;
    }
  }
</style>
